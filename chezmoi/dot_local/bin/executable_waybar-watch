#!/bin/sh
set -eu

log="${XDG_STATE_HOME:-$HOME/.local/state}/waybar/waybar.log"
mkdir -p "$(dirname "$log")"

# One watcher only.
for old in $(pgrep -f "^/bin/sh ${HOME}/.local/bin/waybar-watch" 2>/dev/null || true); do
  if [ "$old" != "$$" ]; then
    kill -KILL "$old" 2>/dev/null || true
  fi
done

while true; do
  pkill -x waybar 2>/dev/null || true
  waybar >>"$log" 2>&1 || true
  sleep 2
done
