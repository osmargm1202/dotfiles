#!/bin/sh
set -eu

wallpaper_dir="${HOME}/Pictures/Wallpapers"
fallback="${HOME}/.config/wallpapers/xnm1-background.png"
interval="${HYPR_WALLPAPER_INTERVAL:-3600}"
state_dir="${XDG_RUNTIME_DIR:-/tmp}"
current_file="${state_dir}/hypr-random-wallpaper.current"
lock_wallpaper="${state_dir}/hypr-current-wallpaper"
daemon_pid_file="${state_dir}/hypr-random-wallpaper.daemon.pid"

mkdir -p "${wallpaper_dir}"

pick_wallpaper() {
  find "${wallpaper_dir}" -type f \( \
    -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.png' -o -iname '*.webp' \
  \) | shuf -n 1
}

ensure_hyprpaper() {
  if ! pgrep -x hyprpaper >/dev/null 2>&1; then
    hyprpaper >/tmp/hyprpaper.log 2>&1 &
    sleep 1
  fi
}

set_wallpaper() {
  wallpaper="$(pick_wallpaper || true)"
  if [ -z "${wallpaper}" ]; then
    wallpaper="${fallback}"
  fi

  ensure_hyprpaper
  hyprctl hyprpaper unload all >/dev/null 2>&1 || true
  hyprctl hyprpaper preload "${wallpaper}" >/dev/null
  hyprctl hyprpaper wallpaper ",${wallpaper}" >/dev/null
  printf '%s\n' "${wallpaper}" > "${current_file}"
  ln -sfn "${wallpaper}" "${lock_wallpaper}"
}

case "${1:-daemon}" in
  next|change)
    set_wallpaper
    ;;
  daemon)
    for old_daemon in $(pgrep -f "^/bin/sh ${HOME}/.local/bin/hypr-random-wallpaper" 2>/dev/null || true); do
      if [ "${old_daemon}" != "$$" ] && kill -0 "${old_daemon}" 2>/dev/null; then
        kill -KILL "${old_daemon}" 2>/dev/null || true
      fi
    done

    if [ -f "${daemon_pid_file}" ]; then
      old_daemon="$(cat "${daemon_pid_file}" 2>/dev/null || true)"
      if [ -n "${old_daemon}" ] && [ "${old_daemon}" != "$$" ] && kill -0 "${old_daemon}" 2>/dev/null; then
        kill -KILL "${old_daemon}" 2>/dev/null || true
      fi
    fi

    printf '%s\n' "$$" > "${daemon_pid_file}"
    while true; do
      set_wallpaper
      sleep "${interval}"
    done
    ;;
  *)
    echo "usage: hypr-random-wallpaper [daemon|next]" >&2
    exit 2
    ;;
esac
