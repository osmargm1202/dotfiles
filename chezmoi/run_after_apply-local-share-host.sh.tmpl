#!/usr/bin/env bash
set -euo pipefail

source_dir='{{ .chezmoi.sourceDir }}'
hostname='{{ .chezmoi.hostname }}'
host_root="$source_dir/hosts/$hostname"
host_share="$host_root/dot_local/share"
host_dms="$host_root/private_dot_config/DankMaterialShell"
target_share="$HOME/.local/share"
target_dms="$HOME/.config/DankMaterialShell"

if [[ ! -d "$host_root" ]]; then
  echo "[chezmoi] no host payloads for $hostname: $host_root"
  exit 0
fi

if [[ -d "$host_share" ]]; then
  mkdir -p "$target_share"

  for name in applications icons; do
    src="$host_share/$name"
    dst="$target_share/$name"

    if [[ -d "$src" ]]; then
      rm -rf "$dst"
      mkdir -p "$dst"
      rsync -a --delete "$src/" "$dst/"
      echo "[chezmoi] synced ~/.local/share/$name for $hostname"
    fi
  done
else
  echo "[chezmoi] no host-local share for $hostname: $host_share"
fi

if [[ -d "$host_dms" ]]; then
  mkdir -p "$target_dms"
  rsync -a "$host_dms/" "$target_dms/"
  echo "[chezmoi] synced host DMS overrides for $hostname"
fi
