# Sway default-style config, adapted to match labwc keybinds.
set $mod Mod4
set $left h
set $down j
set $up k
set $right l
set $term kitty
set $menu fuzzel
set $lock swaylock --config ~/.config/swaylock/config
set $power_menu fish -c wlogout_uniqe

# Outputs / wallpaper
# Managed by ~/.local/bin/sway-random-wallpaper to avoid duplicate swaybg processes.

# Input
input * {
    xkb_layout us,latam
    xkb_variant altgr-intl,
    xkb_options grp:ctrl_space_toggle
    natural_scroll disabled
}

# Look
font pango:JetBrainsMono Nerd Font 11
client.focused          #5e81ac #5e81ac #ffffff #5e81ac #5e81ac
client.focused_inactive #3b4252 #3b4252 #d8dee9 #3b4252 #3b4252
client.unfocused        #2e3440 #2e3440 #d8dee9 #2e3440 #2e3440
client.urgent           #bf616a #bf616a #ffffff #bf616a #bf616a
gaps inner 12
gaps outer 12
default_border pixel 2
default_floating_border pixel 2

# SwayFX effects.
corner_radius 12
smart_corner_radius on
shadows enable
shadow_blur_radius 18
shadow_color #00000070
blur enable
blur_xray disable
blur_passes 3
blur_radius 5
for_window [app_id=".*"] opacity 0.96
for_window [class=".*"] opacity 0.96
for_window [app_id="kitty"] opacity 0.85
for_window [app_id="app.zen_browser.zen"] opacity 0.90
for_window [app_id="zen-browser"] opacity 0.90
for_window [app_id="chromium"] opacity 0.90
for_window [class="Chromium"] opacity 0.90

# Utility windows.
for_window [app_id="org.gnome.Calculator"] floating enable, resize set 420 520, move position center
for_window [app_id="pavucontrol"] floating enable, resize set 760 520, move position center
for_window [app_id="blueman-manager"] floating enable, resize set 760 520, move position center
for_window [app_id="nm-connection-editor"] floating enable, resize set 820 560, move position center
for_window [app_id="wdisplays"] floating enable, resize set 980 640, move position center
for_window [app_id="org.gnome.FileRoller"] floating enable, resize set 820 560, move position center
for_window [window_role="pop-up"] floating enable
for_window [window_type="dialog"] floating enable

# Discord is autostarted minimized; do not force it to scratchpad.
# Env for portals/GTK apps.
exec_always systemctl --user import-environment WAYLAND_DISPLAY DISPLAY XDG_SESSION_TYPE XDG_SESSION_DESKTOP XDG_CURRENT_DESKTOP QT_QPA_PLATFORM QT_QPA_PLATFORMTHEME QT_QPA_PLATFORMTHEME_QT6 ELECTRON_OZONE_PLATFORM_HINT MOZ_ENABLE_WAYLAND NIXOS_OZONE_WL TERMINAL XCURSOR_THEME XCURSOR_SIZE
exec_always dbus-update-activation-environment --systemd WAYLAND_DISPLAY DISPLAY XDG_SESSION_TYPE XDG_SESSION_DESKTOP XDG_CURRENT_DESKTOP QT_QPA_PLATFORM QT_QPA_PLATFORMTHEME QT_QPA_PLATFORMTHEME_QT6 ELECTRON_OZONE_PLATFORM_HINT MOZ_ENABLE_WAYLAND NIXOS_OZONE_WL TERMINAL XCURSOR_THEME XCURSOR_SIZE
exec systemctl --user start graphical-session.target

# Autostart: no DMS, no DM.
exec waybar
exec sh -lc '~/.local/bin/sway-random-wallpaper daemon'
exec swaync
exec nm-applet --indicator
exec blueman-applet
exec gnome-keyring-daemon --start --components=secrets,pkcs11,ssh
exec polkit-gnome-authentication-agent-1
exec nextcloud --background
exec sh -lc 'command -v distrobox >/dev/null 2>&1 && distrobox enter arch -- true'
exec sh -lc 'if command -v discord >/dev/null 2>&1; then discord --start-minimized; elif command -v flatpak >/dev/null 2>&1 && flatpak info com.discordapp.Discord >/dev/null 2>&1; then flatpak run com.discordapp.Discord --start-minimized; fi'
exec wl-paste --type text --watch cliphist store
exec wl-paste --type image --watch cliphist store
exec swayidle -w timeout 300 'swaymsg "output * power off"' resume 'swaymsg "output * power on"' timeout 600 'swaylock --config ~/.config/swaylock/config' timeout 900 'systemctl suspend' before-sleep 'swaylock --config ~/.config/swaylock/config'

# Applications: mirrors labwc rc.xml.
bindsym $mod+slash exec ~/.local/bin/sway-keybindings-help
bindsym $mod+Ctrl+slash exec kitty --hold -e distrobox-enter arch -- tmuxls
bindsym $mod+Return exec $term
bindsym $mod+Shift+Return exec kitty -e distrobox-enter arch
bindsym $mod+e exec sh -lc 'if command -v nautilus >/dev/null 2>&1; then nautilus; elif command -v flatpak >/dev/null 2>&1 && flatpak info org.gnome.Nautilus >/dev/null 2>&1; then flatpak run org.gnome.Nautilus; elif command -v xdg-open >/dev/null 2>&1; then xdg-open .; else echo "explorador no disponible"; fi'
bindsym $mod+w exec flatpak run app.zen_browser.zen
bindsym $mod+a exec kitty --class orgmai-chat -e distrobox-enter arch -- orgmai chat
bindsym $mod+Shift+a exec kitty --class orgmai-chat -e distrobox-enter arch -- orgmai prev
bindsym $mod+Shift+r exec kitty -e distrobox-enter arch -- orgmrnc find

# Standalone stack replacing DMS.
bindsym $mod+v exec sh -lc 'cliphist list | fuzzel --dmenu --prompt "Clipboard> " | cliphist decode | wl-copy'
bindsym $mod+Alt+e exec $power_menu
bindsym $mod+m exec $menu
bindsym $mod+space exec $menu
bindsym $mod+d exec $menu
bindsym $mod+Ctrl+comma exec wdisplays
bindsym $mod+p exec wdisplays
bindsym $mod+F10 exec pavucontrol
bindsym $mod+Alt+l exec $lock
bindsym $mod+n exec swaync-client -t -sw
bindsym $mod+Shift+n exec apostrophe
bindsym $mod+Shift+w exec ~/.local/bin/sway-random-wallpaper next
bindsym $mod+Shift+Escape exec $power_menu
bindsym $mod+s scratchpad show
bindsym $mod+Shift+s move scratchpad
bindsym $mod+Ctrl+s floating disable, move container to workspace current
bindsym $mod+Shift+m exec swaync-client -C
bindsym $mod+Shift+slash exec kitty --hold -e distrobox-enter arch -- tmuxnewz
bindsym $mod+Alt+backslash exec kitty --hold -e distrobox-enter arch -- tmuxdel

# Media keys.
bindsym --locked XF86AudioRaiseVolume exec pamixer -i 3
bindsym --locked XF86AudioLowerVolume exec pamixer -d 3
bindsym --locked XF86AudioMute exec pamixer -t
bindsym --locked XF86AudioMicMute exec pamixer --default-source -t
bindsym --locked XF86AudioPlay exec playerctl play-pause
bindsym --locked XF86AudioStop exec playerctl stop
bindsym --locked XF86AudioPrev exec playerctl previous
bindsym --locked XF86AudioNext exec playerctl next
bindsym --locked XF86MonBrightnessUp exec brightnessctl set 5%+
bindsym --locked XF86MonBrightnessDown exec brightnessctl set 5%-

# Window/session controls.
bindsym $mod+Tab focus mode_toggle
bindsym $mod+q kill

bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right
bindsym $mod+$left focus left
bindsym $mod+$down focus down
bindsym $mod+$up focus up
bindsym $mod+$right focus right

bindsym $mod+Ctrl+Left move left
bindsym $mod+Ctrl+Down move down
bindsym $mod+Ctrl+Up move up
bindsym $mod+Ctrl+Right move right
bindsym $mod+Ctrl+$left move left
bindsym $mod+Ctrl+$down move down
bindsym $mod+Ctrl+$up move up
bindsym $mod+Ctrl+$right move right

bindsym $mod+Home workspace number 1
bindsym $mod+End workspace number 10
bindsym $mod+Ctrl+Home move container to workspace number 1
bindsym $mod+Ctrl+End move container to workspace number 10

bindsym $mod+Shift+Left focus output left
bindsym $mod+Shift+Down focus output down
bindsym $mod+Shift+Up focus output up
bindsym $mod+Shift+Right focus output right
bindsym $mod+Shift+$left focus output left
bindsym $mod+Shift+$down focus output down
bindsym $mod+Shift+$up focus output up
bindsym $mod+Shift+$right focus output right

bindsym $mod+Ctrl+Shift+Left move workspace to output left
bindsym $mod+Ctrl+Shift+Down move workspace to output down
bindsym $mod+Ctrl+Shift+Up move workspace to output up
bindsym $mod+Ctrl+Shift+Right move workspace to output right
bindsym $mod+Ctrl+Shift+$left move workspace to output left
bindsym $mod+Ctrl+Shift+$down move workspace to output down
bindsym $mod+Ctrl+Shift+$up move workspace to output up
bindsym $mod+Ctrl+Shift+$right move workspace to output right

bindsym $mod+Page_Down workspace prev
bindsym $mod+Page_Up workspace next
bindsym $mod+u workspace prev
bindsym $mod+i workspace next
bindsym $mod+Ctrl+Page_Down move container to workspace prev; workspace prev
bindsym $mod+Ctrl+Page_Up move container to workspace next; workspace next
bindsym $mod+Ctrl+u move container to workspace prev; workspace prev
bindsym $mod+Ctrl+i move container to workspace next; workspace next
bindsym $mod+Shift+Page_Down move container to workspace prev
bindsym $mod+Shift+Page_Up move container to workspace next
bindsym $mod+Shift+u move container to workspace prev
bindsym $mod+Shift+i move container to workspace next

set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

bindsym $mod+r layout toggle split tabbed stacking
bindsym $mod+Ctrl+Shift+r resize grow height 20 px or 5 ppt
bindsym $mod+Ctrl+r resize shrink height 20 px or 5 ppt
bindsym $mod+f fullscreen toggle
bindsym $mod+Shift+f fullscreen toggle
bindsym $mod+Ctrl+f fullscreen enable
bindsym $mod+c move position center
bindsym $mod+Ctrl+c focus parent
bindsym $mod+minus resize shrink width 20 px or 5 ppt
bindsym $mod+equal resize grow width 20 px or 5 ppt
bindsym $mod+Shift+minus resize shrink height 20 px or 5 ppt
bindsym $mod+Shift+equal resize grow height 20 px or 5 ppt
bindsym $mod+Shift+space floating toggle
bindsym $mod+Ctrl+Shift+space focus mode_toggle
bindsym $mod+t border toggle

# Screenshots.
bindsym Print exec sh -lc 'grim -g "$(slurp)" - | swappy -f -'
bindsym Ctrl+Print exec sh -lc 'grim - | swappy -f -'
bindsym Alt+Print exec sh -lc 'grim -g "$(slurp)" - | swappy -f -'

# Exit / monitors.
bindsym $mod+Shift+e exit
bindsym Ctrl+Alt+Delete exit
bindsym $mod+Shift+p exec swaymsg 'output * power off'
bindsym $mod+Ctrl+Shift+p exec swaymsg 'output * power on'

# Mouse.
floating_modifier $mod normal
# Sway has no direct equivalent for niri keyboard-shortcuts-inhibit toggle.
# Keep key free for apps.

include /etc/sway/config.d/*
