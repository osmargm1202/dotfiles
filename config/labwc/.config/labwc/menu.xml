<?xml version="1.0"?>
<openbox_menu xmlns="http://openbox.org/3.4/menu">
  <menu id="root-menu" label="labwc">
    <item label="Terminal (kitty)">
      <action name="Execute"><command>kitty</command></action>
    </item>
    <item label="Terminal Arch distrobox">
      <action name="Execute"><command>kitty -e distrobox-enter arch</command></action>
    </item>
    <item label="Arch orgmai chat">
      <action name="Execute"><command>kitty --class orgmai-chat -e distrobox-enter arch -- orgmai chat</command></action>
    </item>
    <separator />
    <item label="Files (Nautilus)">
      <action name="Execute"><command>nautilus</command></action>
    </item>
    <item label="Text Editor">
      <action name="Execute"><command>gnome-text-editor</command></action>
    </item>
    <item label="Calculator">
      <action name="Execute"><command>gnome-calculator</command></action>
    </item>
    <item label="Papers">
      <action name="Execute"><command>papers</command></action>
    </item>
    <item label="Zen Browser">
      <action name="Execute"><command>flatpak run app.zen_browser.zen</command></action>
    </item>
    <separator />
    <item label="DMS Spotlight">
      <action name="Execute"><command>dms ipc call spotlight toggle</command></action>
    </item>
    <item label="DMS Control Center">
      <action name="Execute"><command>dms ipc call control-center toggle</command></action>
    </item>
    <item label="DMS Notifications">
      <action name="Execute"><command>dms ipc call notifications toggle</command></action>
    </item>
    <item label="DMS Settings">
      <action name="Execute"><command>dms ipc call settings focusOrToggle</command></action>
    </item>
    <item label="DMS Keybinds">
      <action name="Execute"><command>dms ipc call keybinds toggle labwc</command></action>
    </item>
    <separator />
    <item label="Reconfigure labwc">
      <action name="Reconfigure" />
    </item>
    <item label="Exit labwc">
      <action name="Exit" />
    </item>
  </menu>
</openbox_menu>
