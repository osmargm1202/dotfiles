#!/usr/bin/env bash
set -euo pipefail

CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}"
PINNED_FILE="$CACHE_DIR/nwg-dock-pinned"
mkdir -p "$CACHE_DIR"

# nwg-dock stores pins in XDG cache. Seed once; later user pin/unpin changes survive.
if [ ! -s "$PINNED_FILE" ]; then
  cat >"$PINNED_FILE" <<'EOF'
fuzzel
app.zen_browser.zen
org.gnome.Nautilus
kitty
com.discordapp.Discord
md.obsidian.Obsidian
chromium
windows-rdp
thunderbird
EOF
fi

pgrep -u "$USER" -x nwg-panel >/dev/null 2>&1 || nwg-panel >/tmp/labwc-nwg-panel.log 2>&1 &

if ! pgrep -u "$USER" -x nwg-dock >/dev/null 2>&1; then
  nwg-dock \
    -r \
    -p bottom \
    -l top \
    -i 48 \
    -mb 10 \
    -nows \
    -c fuzzel \
    -lp start \
    >/tmp/labwc-nwg-dock.log 2>&1 &
fi
