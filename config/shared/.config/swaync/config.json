{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "control-center-margin-top": 14,
  "control-center-margin-bottom": 14,
  "control-center-margin-right": 14,
  "control-center-margin-left": 14,
  "notification-icon-size": 64,
  "notification-body-image-height": 120,
  "notification-body-image-width": 220,
  "timeout": 8,
  "timeout-low": 4,
  "timeout-critical": 0,
  "fit-to-screen": true,
  "control-center-width": 420,
  "control-center-height": 760,
  "notification-window-width": 420,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 180,
  "hide-on-clear": false,
  "hide-on-action": true,
  "script-fail-notify": true,
  "scripts": {
    "focus-app-on-action": {
      "exec": "orgm-hypr notify focus-app",
      "app-name": ".*",
      "run-on": "receive"
    }
  },
  "widgets": [
    "title",
    "dnd",
    "notifications"
  ],
  "widget-config": {
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": "Clear"
    },
    "dnd": {
      "text": "Do Not Disturb"
    }
  }
}
