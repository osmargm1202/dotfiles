    "name": "top_bar",
    "layer": "top",
    "position": "top",
    "height": 47,
    "spacing": 5,
    "margin-top": 10,
    "margin-left": 14,
    "margin-right": 24,
    "modules-left": [
      "group/workspaces",
      "group/system",
      "hyprland/submap"
    ],
    "modules-center": [
      "custom/day_month",
      "custom/time",
      "custom/date"
    ],
    "modules-right": [
      "privacy",
      "tray",
      "custom/wallpaper",
      "bluetooth",
      "network",
      "custom/logout_menu"
    ],
    "group/workspaces": {
      "orientation": "horizontal",
      "modules": [
        "custom/menu",
        "custom/ws_1",
        "custom/ws_2",
        "custom/ws_3",
        "custom/ws_4",
        "custom/ws_5",
        "custom/ws_6",
