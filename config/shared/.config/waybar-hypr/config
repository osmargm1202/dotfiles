    "modules-left": [
      "custom/orgm_logo",
      "custom/user",
      "hyprland/window"
    ],
    "modules-center": [
      "idle_inhibitor",
      "mpris"
    ],
    "modules-right": [
      "group/usage",
      "custom/kbd_layout",
      "custom/keybindings_help"
    ],
    "custom/orgm_logo": {
      "format": "NixOS",
      "tooltip": true,
      "tooltip-format": "Abrir men├║ ORGM-HYPR",
      "on-click": "hypr-main-menu"
    },
    "custom/user": {
      "format": "´îô  osmarg",
      "tooltip": false
    },
    "hyprland/window": {
      "format": "{}",
      "max-length": 80,
      "separate-outputs": true
    },
    "idle_inhibitor": {
      "format": "{icon}",
      "format-icons": {
        "activated": "¾░àÂ",
        "deactivated": "¾░¥¬"
      }
    },
    "mpris": {
      "format": "{player_icon} {dynamic}",
      "format-paused": "{status_icon} {dynamic}",
      "player-icons": {
        "default": "¾░Äê"
      },
      "status-icons": {
        "paused": "¾░Åñ"
      },
      "max-length": 45,
      "on-click": "playerctl play-pause",
      "on-click-right": "playerctl next",
      "on-click-middle": "playerctl previous"
    },
    "custom/metric_cpu": {
      "exec": "waybar-metric-widget cpu",
      "return-type": "json",
      "interval": 2,
      "format": "{}",
      "markup": "pango",
      "escape": false,
      "tooltip": true,
      "on-click": "kitty -e btop"
    },
    "custom/metric_gpu": {
