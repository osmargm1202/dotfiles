[
  {
    "name": "top_bar",
    "layer": "top",
    "position": "top",
    "height": 33,
    "spacing": 5,
    "margin-top": 0,
    "margin-left": 0,
    "margin-right": 0,
    "modules-left": [
      "group/workspaces",
      "group/system",
      "hyprland/submap"
    ],
    "modules-center": [
      "custom/day_month",
      "custom/time",
      "custom/date"
    ],
    "modules-right": [
      "privacy",
      "tray",
      "custom/clipboard",
      "custom/theme_toggle",
      "custom/logout_menu"
    ],
    "group/workspaces": {
      "orientation": "horizontal",
      "modules": [
        "custom/menu",
        "custom/ws_1",
        "custom/ws_2",
        "custom/ws_3",
        "custom/ws_4",
        "custom/ws_5",
        "custom/ws_6",
        "custom/ws_7",
        "custom/ws_8",
        "custom/ws_9",
        "custom/ws_10"
      ]
    },
    "custom/menu": {
      "format": "",
      "tooltip": true,
      "tooltip-format": "Abrir menú ORGM-HYPR",
      "on-click": "hypr-main-menu"
    },
    "custom/ws_1": {
      "exec": "hypr-workspace-button status 1",
      "return-type": "json",
      "interval": 1,
      "format": "{}",
      "tooltip": true,
      "on-click": "hypr-workspace-button click 1"
    },
    "custom/ws_2": {
      "exec": "hypr-workspace-button status 2",
      "return-type": "json",
      "interval": 1,
      "format": "{}",
      "tooltip": true,
      "on-click": "hypr-workspace-button click 2"
    },
    "custom/ws_3": {
      "exec": "hypr-workspace-button status 3",
      "return-type": "json",
      "interval": 1,
      "format": "{}",
      "tooltip": true,
      "on-click": "hypr-workspace-button click 3"
    },
    "custom/ws_4": {
      "exec": "hypr-workspace-button status 4",
      "return-type": "json",
      "interval": 1,
      "format": "{}",
      "tooltip": true,
      "on-click": "hypr-workspace-button click 4"
    },
    "custom/ws_5": {
      "exec": "hypr-workspace-button status 5",
      "return-type": "json",
      "interval": 1,
      "format": "{}",
      "tooltip": true,
      "on-click": "hypr-workspace-button click 5"
    },
    "custom/ws_6": {
      "exec": "hypr-workspace-button status 6",
      "return-type": "json",
      "interval": 1,
      "format": "{}",
      "tooltip": true,
      "on-click": "hypr-workspace-button click 6"
    },
    "custom/ws_7": {
      "exec": "hypr-workspace-button status 7",
      "return-type": "json",
      "interval": 1,
      "format": "{}",
      "tooltip": true,
      "on-click": "hypr-workspace-button click 7"
    },
    "custom/ws_8": {
      "exec": "hypr-workspace-button status 8",
      "return-type": "json",
      "interval": 1,
      "format": "{}",
      "tooltip": true,
      "on-click": "hypr-workspace-button click 8"
    },
    "custom/ws_9": {
      "exec": "hypr-workspace-button status 9",
      "return-type": "json",
      "interval": 1,
      "format": "{}",
      "tooltip": true,
      "on-click": "hypr-workspace-button click 9"
    },
    "custom/ws_10": {
      "exec": "hypr-workspace-button status 10",
      "return-type": "json",
      "interval": 1,
      "format": "{}",
      "tooltip": true,
      "on-click": "hypr-workspace-button click 10"
    },
    "hyprland/submap": {
      "format": "<span color='#a6da95'>Mode:</span> {}",
      "tooltip": false
    },
    "custom/day_month": {
      "exec": "waybar-day-month-es",
      "interval": 60,
      "tooltip": false
    },
    "custom/time": {
      "exec": "waybar-time-ampm",
      "interval": 1,
      "tooltip": false
    },
    "custom/date": {
      "exec": "waybar-date-es",
      "interval": 60,
      "tooltip": false
    },
    "custom/wallpaper": {
      "format": "",
      "tooltip": true,
      "tooltip-format": "Wallpaper aleatorio",
      "on-click": "orgm-wallpaper random-static",
      "on-click-right": "orgm-wallpaper pick"
    },
    "custom/usb_devices": {
      "exec": "hypr-usb-menu status",
      "return-type": "json",
      "interval": 5,
      "format": "{}",
      "tooltip": true,
      "on-click": "hypr-usb-menu open",
      "on-click-right": "hypr-usb-menu nickname"
    },
    "custom/memclean": {
      "exec": "memclean-dev status",
      "return-type": "json",
      "interval": 10,
      "format": "{}",
      "tooltip": true,
      "on-click": "memclean-dev clean",
      "on-click-right": "kitty --class memclean-dev -e fish -lc 'memclean-dev dry-run; echo; read -P \"enter...\"'",
      "on-click-middle": "kitty -e btop"
    },
    "custom/nixclean": {
      "format": "󰃢",
      "tooltip": true,
      "tooltip-format": "Limpiar Nix, journal, papelera, Flatpak unused",
      "on-click": "kitty --class nixclean -e fish -lc 'nixclean; read -P \"enter...\"'"
    },
    "custom/headset_reconnect": {
      "format": "󰋋",
      "tooltip": true,
      "tooltip-format": "Reconectar headset USB",
      "on-click": "hypr-bluetooth-reconnect"
    },
    "custom/hardware_fetch": {
      "format": "󰌢",
      "tooltip": true,
      "tooltip-format": "Hardware / Fastfetch",
      "on-click": "kitty --title hardware-fastfetch -e fish -lc 'fastfetch --config ~/.config/fastfetch/hardware.jsonc; echo; exec fish -i'"
    },
    "custom/pi_status": {
      "exec": "waybar-pi-status",
      "return-type": "json",
      "interval": 900,
      "format": "{}",
      "tooltip": true,
      "on-click": "kitty --title pi-update -e distrobox-enter arch -- fish -lc 'pi update; waybar-pi-status refresh >/dev/null 2>&1; echo; exec fish -i'"
    },
    "bluetooth": {
      "format": "󰂯",
      "format-disabled": "󰂲",
      "format-connected": "󰂱 {device_alias}",
      "format-connected-battery": "󰂱 {device_alias} (󰥉 {device_battery_percentage}%)",
      "tooltip-format": "{controller_alias}\t{controller_address} ({status})\n\n{num_connections} connected",
      "tooltip-format-disabled": "bluetooth off",
      "tooltip-format-connected": "{controller_alias}\t{controller_address} ({status})\n\n{num_connections} connected\n\n{device_enumerate}",
      "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
      "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t({device_battery_percentage}%)",
      "max-length": 35,
      "on-click": "blueman-manager"
    },
    "cpu": {
      "format": " {usage}%",
      "tooltip": true,
      "on-click": "kitty -e btop"
    },
    "memory": {
      "format": " {percentage}%",
      "tooltip-format": "{used:0.1f}G / {total:0.1f}G",
      "on-click": "kitty -e btop"
    },
    "temperature": {
      "format": " {temperatureC}°C",
      "critical-threshold": 85,
      "on-click": "kitty -e btop"
    },
    "disk#ssd": {
      "path": "/",
      "format": "󰋊 SSD {percentage_used}%",
      "tooltip-format": "{used} used / {total} total",
      "on-click": "kitty -e btop"
    },
    "custom/swap": {
      "exec": "waybar-swap-usage",
      "interval": 5,
      "tooltip": false,
      "on-click": "kitty -e btop"
    },
    "group/system": {
      "orientation": "horizontal",
      "modules": [
        "backlight",
        "battery",
        "pulseaudio",
        "pulseaudio/slider",
        "pulseaudio#microphone",
        "pulseaudio/slider#microphone"
      ]
    },
    "backlight": {
      "format": "{icon} {percent}%",
      "format-icons": [
        "󰃞",
        "󰃟",
        "󰃠"
      ]
    },
    "pulseaudio": {
      "format": "{icon}",
      "format-muted": "󰝟",
      "format-icons": {
        "default": [
          "",
          "",
          ""
        ]
      },
      "on-click": "pamixer -t",
      "on-click-middle": "hypr-audio-device-menu output",
      "on-click-right": "pavucontrol",
      "max-volume": 150
    },
    "pulseaudio/slider": {
      "min": 0,
      "max": 150,
      "orientation": "horizontal"
    },
    "pulseaudio#microphone": {
      "target": "source",
      "format": "{format_source}",
      "format-source": "󰍬",
      "format-source-muted": "󰍭",
      "on-click": "pamixer --default-source -t",
      "on-click-middle": "hypr-audio-device-menu input",
      "on-click-right": "pavucontrol",
      "max-volume": 150
    },
    "pulseaudio/slider#microphone": {
      "target": "source",
      "min": 0,
      "max": 150,
      "orientation": "horizontal"
    },
    "battery": {
      "states": {
        "warning": 30,
        "critical": 15
      },
      "format": "{icon} {capacity}%",
      "format-charging": "󰂄 {capacity}% ",
      "format-plugged": "󰚥 {capacity}%",
      "format-full": "󰁹 {capacity}%",
      "tooltip-format": "{capacity}% {timeTo} {power}W",
      "format-icons": [
        "󰁺",
        "󰁻",
        "󰁼",
        "󰁽",
        "󰁾",
        "󰁿",
        "󰂀",
        "󰂁",
        "󰂂",
        "󰁹"
      ]
    },
    "custom/power_profile": {
      "exec-if": "waybar-power-profile check",
      "exec": "waybar-power-profile status",
      "return-type": "json",
      "interval": 10,
      "format": "{}",
      "tooltip": true,
      "on-click": "waybar-power-profile pick"
    },
    "network": {
      "format": "󰤭",
      "format-wifi": "{icon} ({signalStrength}%) {essid}",
      "format-icons": [
        "󰤯",
        "󰤟",
        "󰤢",
        "󰤥",
        "󰤨"
      ],
      "format-ethernet": "󰈀 {ipaddr}/{cidr}",
      "format-disconnected": "󰤫 Disconnected",
      "tooltip-format-wifi": "SSID: {essid} ({signalStrength}%)\nInterface: {ifname}\nIP: {ipaddr}\nGW: {gwaddr}\n\n<span color='#a6da95'> {bandwidthUpBits}</span>\t<span color='#ee99a0'> {bandwidthDownBits}</span>",
      "tooltip-format-ethernet": "Interface: {ifname}\nIP: {ipaddr}\nGW: {gwaddr}\n\n<span color='#a6da95'> {bandwidthUpBits}</span>\t<span color='#ee99a0'> {bandwidthDownBits}</span>",
      "tooltip-format-disconnected": "<span color='#ed8796'>disconnected</span>",
      "max-length": 35,
      "on-click": "nm-connection-editor"
    },
    "privacy": {
      "icon-spacing": 5,
      "icon-size": 16,
      "transition-duration": 250,
      "modules": [
        {
          "type": "audio-in"
        },
        {
          "type": "screenshare"
        }
      ]
    },
    "tray": {
      "icon-size": 21,
      "spacing": 10
    },
    "custom/hypr_config_editor": {
      "format": "",
      "tooltip": true,
      "tooltip-format": "Editar configs Hyprland",
      "on-click": "hypr-config-editor"
    },
    "custom/logout_menu": {
      "format": "⏻",
      "tooltip": false,
      "on-click": "hypr-power-menu"
    },
    "custom/clipboard": {
      "format": "",
      "tooltip": true,
      "tooltip-format": "Historial clipboard",
      "on-click": "hypr-rofi-clipboard"
    },
    "custom/theme_toggle": {
      "exec": "waybar-theme-toggle status",
      "return-type": "json",
      "interval": 5,
      "format": "{}",
      "tooltip": true,
      "on-click": "waybar-theme-toggle toggle"
    }
  },
  {
    "name": "bottom_bar",
    "layer": "top",
    "position": "bottom",
    "height": 42,
    "spacing": 5,
    "margin-bottom": 0,
    "margin-left": 0,
    "margin-right": 0,
    "modules-left": [
      "custom/orgm_logo",
      "custom/user",
      "hyprland/window"
    ],
    "modules-center": [
      "idle_inhibitor",
      "mpris"
    ],
    "modules-right": [
      "custom/wallpaper",
      "custom/usb_devices",
      "custom/headset_reconnect",
      "custom/memclean",
      "custom/nixclean",
      "custom/hardware_fetch",
      "custom/pi_status",
      "custom/hypr_config_editor",
      "custom/conky_toggle",
      "custom/kbd_layout",
      "custom/keybindings_help",
      "custom/power_profile"
    ],
    "custom/orgm_logo": {
      "format": "NixOS",
      "tooltip": true,
      "tooltip-format": "Abrir menú ORGM-HYPR",
      "on-click": "hypr-main-menu"
    },
    "custom/user": {
      "format": "  osmarg",
      "tooltip": false
    },
    "hyprland/window": {
      "format": "{}",
      "max-length": 80,
      "separate-outputs": true
    },
    "idle_inhibitor": {
      "format": "{icon}",
      "format-icons": {
        "activated": "󰅶",
        "deactivated": "󰾪"
      }
    },
    "mpris": {
      "format": "{player_icon} {dynamic}",
      "format-paused": "{status_icon} {dynamic}",
      "player-icons": {
        "default": "󰎈"
      },
      "status-icons": {
        "paused": "󰏤"
      },
      "max-length": 45,
      "on-click": "playerctl play-pause",
      "on-click-right": "playerctl next",
      "on-click-middle": "playerctl previous"
    },
    "custom/metric_cpu": {
      "exec": "waybar-metric-widget cpu",
      "return-type": "json",
      "interval": 2,
      "format": "{}",
      "markup": "pango",
      "escape": false,
      "tooltip": true,
      "on-click": "kitty -e btop"
    },
    "custom/metric_gpu": {
      "exec": "waybar-metric-widget gpu",
      "return-type": "json",
      "interval": 3,
      "format": "{}",
      "markup": "pango",
      "escape": false,
      "tooltip": true,
      "on-click": "kitty -e btop"
    },
    "custom/metric_ram": {
      "exec": "waybar-metric-widget ram",
      "return-type": "json",
      "interval": 5,
      "format": "{}",
      "markup": "pango",
      "escape": false,
      "tooltip": true,
      "on-click": "kitty -e btop"
    },
    "custom/metric_ssd": {
      "exec": "waybar-metric-widget ssd",
      "return-type": "json",
      "interval": 10,
      "format": "{}",
      "markup": "pango",
      "escape": false,
      "tooltip": true,
      "on-click": "kitty -e btop"
    },
    "custom/metric_swap": {
      "exec": "waybar-metric-widget swap",
      "return-type": "json",
      "interval": 5,
      "format": "{}",
      "markup": "pango",
      "escape": false,
      "tooltip": true,
      "on-click": "kitty -e btop"
    },
    "group/usage": {
      "orientation": "horizontal",
      "modules": [
        "custom/metric_cpu",
        "custom/metric_gpu",
        "custom/metric_ram",
        "custom/metric_ssd",
        "custom/metric_swap"
      ]
    },
    "backlight": {
      "format": "{icon} {percent}%",
      "format-icons": [
        "󰃞",
        "󰃟",
        "󰃠"
      ]
    },
    "pulseaudio": {
      "format": "{icon} {volume}%",
      "format-muted": "󰝟 muted",
      "format-icons": {
        "default": [
          "",
          "",
          ""
        ]
      },
      "on-click": "pavucontrol"
    },
    "custom/kbd_layout": {
      "exec": "~/.config/waybar-hypr/kbd-layout.sh",
      "interval": 1,
      "tooltip": false,
      "on-click": "~/.local/bin/kbd-layout-next"
    },
    "custom/keybindings_help": {
      "format": "?",
      "tooltip": true,
      "tooltip-format": "Atajos Hyprland (Win+/)\nClick: abrir helper\nClick derecho: actualizar lista",
      "on-click": "hypr-keyhelper toggle",
      "on-click-right": "hypr-keyhelper init"
    },
    "custom/power_profile": {
      "exec-if": "waybar-power-profile check",
      "exec": "waybar-power-profile status",
      "return-type": "json",
      "interval": 10,
      "format": "{}",
      "tooltip": true,
      "on-click": "waybar-power-profile pick"
    },
    "battery": {
      "states": {
        "warning": 30,
        "critical": 15
      },
      "format": "{icon} {capacity}%",
      "format-charging": "󰂄 {capacity}% ",
      "format-plugged": "󰚥 {capacity}%",
      "format-full": "󰁹 {capacity}%",
      "tooltip-format": "{capacity}% {timeTo} {power}W",
      "format-icons": [
        "󰁺",
        "󰁻",
        "󰁼",
        "󰁽",
        "󰁾",
        "󰁿",
        "󰂀",
        "󰂁",
        "󰂂",
        "󰁹"
      ]
    },
    "custom/wallpaper": {
      "format": "",
      "tooltip": true,
      "tooltip-format": "Wallpaper aleatorio",
      "on-click": "orgm-wallpaper random-static",
      "on-click-right": "orgm-wallpaper pick"
    },

    "custom/usb_devices": {
      "exec": "hypr-usb-menu status",
      "return-type": "json",
      "interval": 5,
      "format": "{}",
      "tooltip": true,
      "on-click": "hypr-usb-menu open",
      "on-click-right": "hypr-usb-menu nickname"
    },

    "custom/headset_reconnect": {
      "format": "󰋋",
      "tooltip": true,
      "tooltip-format": "Reconectar headset USB",
      "on-click": "hypr-bluetooth-reconnect"
    },

    "custom/memclean": {
      "exec": "memclean-dev status",
      "return-type": "json",
      "interval": 10,
      "format": "{}",
      "tooltip": true,
      "on-click": "memclean-dev clean",
      "on-click-right": "kitty --class memclean-dev -e fish -lc 'memclean-dev dry-run; echo; read -P \"enter...\"'",
      "on-click-middle": "kitty -e btop"
    },

    "custom/nixclean": {
      "format": "󰃢",
      "tooltip": true,
      "tooltip-format": "Limpiar Nix, journal, papelera, Flatpak unused",
      "on-click": "kitty --class nixclean -e fish -lc 'nixclean; read -P \"enter...\"'"
    },

    "custom/hardware_fetch": {
      "format": "󰌢",
      "tooltip": true,
      "tooltip-format": "Hardware / Fastfetch",
      "on-click": "kitty --title hardware-fastfetch -e fish -lc 'fastfetch --config ~/.config/fastfetch/hardware.jsonc; echo; exec fish -i'"
    },

    "custom/pi_status": {
      "exec": "waybar-pi-status",
      "return-type": "json",
      "interval": 900,
      "format": "{}",
      "tooltip": true,
      "on-click": "kitty --title pi-update -e distrobox-enter arch -- fish -lc 'pi update; waybar-pi-status refresh >/dev/null 2>&1; echo; exec fish -i'"
    },

    "custom/hypr_config_editor": {
      "format": "",
      "tooltip": true,
      "tooltip-format": "Editar configs Hyprland",
      "on-click": "hypr-config-editor"
    },

    "custom/conky_toggle": {
      "format": "󰥔",
      "tooltip": true,
      "tooltip-format": "Ver stats 4s encima de ventanas",
      "on-click": "hypr-conky-toggle"
    }
  },
  {
    "name": "dock_spacer",
    "layer": "top",
    "position": "right",
    "width": 80,
    "exclusive": true,
    "passthrough": true,
    "modules-center": ["custom/dock_spacer"],
    "custom/dock_spacer": {
      "format": ""
    }
  }
]
