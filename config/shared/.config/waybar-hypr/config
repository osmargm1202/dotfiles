    "hyprland/submap": {
      "format": "<span color='#a6da95'>Mode:</span> {}",
      "tooltip": false
    },
    "custom/day_month": {
      "exec": "waybar-day-month-es",
      "interval": 60,
      "tooltip": false
    },
    "custom/time": {
      "exec": "waybar-time-ampm",
      "interval": 1,
      "tooltip": false
