    "custom/usb_devices": {
      "exec": "hypr-usb-menu status",
      "return-type": "json",
      "interval": 5,
      "format": "{}",
      "tooltip": true,
      "on-click": "hypr-usb-menu open",
      "on-click-right": "hypr-usb-menu nickname"
    },
    "custom/nixclean": {
      "format": "¾░âó",
      "tooltip": true,
      "tooltip-format": "Limpiar Nix, journal, papelera, Flatpak unused",
      "on-click": "kitty --class nixclean -e fish -lc 'nixclean; read -P \"enter...\"'"
    },
    "custom/headset_reconnect": {
      "format": "¾░ïï",
      "tooltip": true,
      "tooltip-format": "Reconectar headset USB",
      "on-click": "hypr-bluetooth-reconnect"
    },
    "custom/hardware_fetch": {
      "format": "¾░îó",
      "tooltip": true,
      "tooltip-format": "Hardware / Fastfetch",
      "on-click": "kitty --title hardware-fastfetch -e fish -lc 'fastfetch --config ~/.config/fastfetch/hardware.jsonc; echo; exec fish -i'"
    },
    "custom/pi_status": {
      "exec": "waybar-pi-status",
      "return-type": "json",
      "interval": 900,
      "format": "{}",
      "tooltip": true,
      "on-click": "kitty --title pi-update -e distrobox-enter arch -- fish -lc 'pi update; waybar-pi-status refresh >/dev/null 2>&1; echo; exec fish -i'"
    },
    "bluetooth": {
      "format": "¾░é»",
      "format-disabled": "¾░é▓",
      "format-connected": "¾░é▒ {device_alias}",
      "format-connected-battery": "¾░é▒ {device_alias} (¾░Ñë {device_battery_percentage}%)",
      "tooltip-format": "{controller_alias}\t{controller_address} ({status})\n\n{num_connections} connected",
      "tooltip-format-disabled": "bluetooth off",
      "tooltip-format-connected": "{controller_alias}\t{controller_address} ({status})\n\n{num_connections} connected\n\n{device_enumerate}",
      "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
      "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t({device_battery_percentage}%)",
      "max-length": 35,
      "on-click": "blueman-manager"
    },
    "cpu": {
      "format": "´Æ╝ {usage}%",
      "tooltip": true,
      "on-click": "kitty -e btop"
    },
    "memory": {
      "format": "¯┐à {percentage}%",
      "tooltip-format": "{used:0.1f}G / {total:0.1f}G",
      "on-click": "kitty -e btop"
    },
    "temperature": {
      "format": "´ïë {temperatureC}┬░C",
      "critical-threshold": 85,
      "on-click": "kitty -e btop"
    },
    "disk#ssd": {
      "path": "/",
      "format": "¾░ïè SSD {percentage_used}%",
      "tooltip-format": "{used} used / {total} total",
      "on-click": "kitty -e btop"
    },
    "custom/swap": {
      "exec": "waybar-swap-usage",
      "interval": 5,
      "tooltip": false,
      "on-click": "kitty -e btop"
    },
    "group/system": {
      "orientation": "horizontal",
      "modules": [
        "backlight",
        "battery",
        "pulseaudio",
        "pulseaudio/slider",
        "pulseaudio#microphone",
        "pulseaudio/slider#microphone"
      ]
    },
    "backlight": {
      "format": "{icon} {percent}%",
      "format-icons": [
        "¾░â×",
        "¾░âƒ",
        "¾░âá"
      ]
    },
    "pulseaudio": {
      "format": "{icon}",
      "format-muted": "¾░Øƒ",
      "format-icons": {
        "default": [
          "´Çª",
          "´Çº",
          "´Ç¿"
        ]
      },
      "on-click": "pamixer -t",
      "on-click-middle": "hypr-audio-device-menu output",
      "on-click-right": "pavucontrol",
      "max-volume": 150
    },
    "pulseaudio/slider": {
      "min": 0,
      "max": 150,
      "orientation": "horizontal"
    },
    "pulseaudio#microphone": {
      "target": "source",
      "format": "{format_source}",
      "format-source": "¾░ì¼",
      "format-source-muted": "¾░ì¡",
