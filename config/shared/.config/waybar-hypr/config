    },
    "custom/pi_status": {
      "exec": "waybar-pi-status",
      "return-type": "json",
      "interval": 900,
      "format": "{}",
      "tooltip": true,
      "on-click": "kitty --title pi-update -e distrobox-enter arch -- fish -lc 'pi update; waybar-pi-status refresh >/dev/null 2>&1; echo; exec fish -i'"
    },
    "bluetooth": {
