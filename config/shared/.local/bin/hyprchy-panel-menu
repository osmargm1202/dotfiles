#!/usr/bin/env bash
set -euo pipefail

theme="${HYPRCHY_ROFI_THEME:-$HOME/.config/rofi-hyprchy/control-center.rasi}"
choice="$(printf '%s\n' '󱂬 Restart HyprPanel' '󰓛 Stop HyprPanel' '󰝰 Open HyprPanel config' '󰅖 Cancel' | rofi -dmenu -i -p 'Panels' -theme "$theme" || true)"

case "$choice" in
  *'Restart') hyprpanel -q 2>/dev/null || true; exec hyprpanel ;;
  *'Stop') exec hyprpanel -q ;;
  *'config') exec nautilus "$HOME/.config/hyprpanel" ;;
  *) exit 0 ;;
esac
