#!/usr/bin/env bash
# Show stats overlay above all windows for 4s. Background conky (layer-shell) stays untouched.
LOCK=/tmp/hypr-conky-overlay.lock
if [ -f "$LOCK" ]; then exit 0; fi
touch "$LOCK"
conky -c ~/.config/conky/conky-top.conf -d
(sleep 4 && pkill -f "conky-top.conf" 2>/dev/null && rm -f "$LOCK") &
disown $!
