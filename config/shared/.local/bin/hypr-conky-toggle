#!/usr/bin/env bash
# Show stats overlay above all windows for 4s. Background conky (layer-shell) stays untouched.
# If already showing, kill it early.
if pgrep -f "conky-top.conf" >/dev/null 2>&1; then
    pkill -f "conky-top.conf" 2>/dev/null || true
    exit 0
fi
conky -c ~/.config/conky/conky-top.conf -d
(sleep 4 && pkill -f "conky-top.conf" 2>/dev/null) &
disown $!
