#!/usr/bin/env bash
set -euo pipefail

lib="${HYPR_ROFI_LIB:-$HOME/.local/bin/hypr-rofi-lib}"
# shellcheck disable=SC1090
. "$lib"

current="$(orgm-theme current 2>/dev/null || echo orgm-dark)"
choice="$(printf '%s\n' \
  "󰔎 Toggle ($current)" \
  '󰖔 orgm-dark' \
  '󰖨 orgm-light' \
  '󰒓 Status' \
  '󰅖 Cancel' \
  | hypr_rofi_dmenu 'Theme' || true)"

case "$choice" in
  *Toggle*) exec orgm-theme toggle ;;
  *orgm-dark*) exec orgm-theme apply orgm-dark ;;
  *orgm-light*) exec orgm-theme apply orgm-light ;;
  *Status*) orgm-theme status | hypr_rofi_dmenu 'Theme status' >/dev/null || true ;;
  *) exit 0 ;;
esac
