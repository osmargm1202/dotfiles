#!/usr/bin/env bash
set -euo pipefail

theme="${HYPR_ROFI_THEME:-$HOME/.config/rofi/hypr-menu.rasi}"
env_file="${HYPR_ROFI_ENV:-$HOME/.config/rofi/hypr-menu.env}"

if [ -f "$env_file" ]; then
  # shellcheck disable=SC1090
  . "$env_file"
fi

scale="${HYPR_ROFI_SCALE:-1.00}"
width="${HYPR_ROFI_POWER_WIDTH:-$(awk -v s="$scale" 'BEGIN { printf "%dpx", 360 * s }')}"
font_size="${HYPR_ROFI_FONT_SIZE:-$(awk -v s="$scale" 'BEGIN { printf "%d", 12 * s }')}"
icon_size="${HYPR_ROFI_POWER_ICON_SIZE:-$(awk -v s="$scale" 'BEGIN { printf "%dpx", 22 * s }')}"
padding_y="${HYPR_ROFI_POWER_PADDING_Y:-$(awk -v s="$scale" 'BEGIN { printf "%dpx", 5 * s }')}"
padding_x="${HYPR_ROFI_POWER_PADDING_X:-$(awk -v s="$scale" 'BEGIN { printf "%dpx", 8 * s }')}"
input_padding="${HYPR_ROFI_POWER_INPUT_PADDING:-$(awk -v s="$scale" 'BEGIN { printf "%dpx", 8 * s }')}"

choice="$(printf '%s\n' '󰌾 Lock' '󰤄 Suspend' '󰒲 Hibernate' '󰗼 Logout' '󰜉 Reboot' '󰐥 Power off' '󰅖 Cancel' \
  | rofi -dmenu -i -p 'Power' -theme "$theme" \
      -theme-str "configuration { font: \"JetBrainsMono Nerd Font $font_size\"; } window { width: $width; } listview { lines: 7; } element { padding: $padding_y $padding_x; } element-icon { size: $icon_size; } inputbar { padding: $input_padding; }" \
  || true)"

case "$choice" in
  *'Lock') exec "$HOME/.local/bin/hypr-lock" ;;
  *'Suspend') systemctl suspend ;;
  *'Hibernate') systemctl hibernate ;;
  *'Logout') hyprctl dispatch exit ;;
  *'Reboot') systemctl reboot ;;
  *'Power off') systemctl poweroff ;;
  *) exit 0 ;;
esac
