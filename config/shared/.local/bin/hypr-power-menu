#!/usr/bin/env bash
set -euo pipefail

theme="${HYPR_ROFI_THEME:-$HOME/.config/rofi/hypr-menu.rasi}"
choice="$(printf '%s\n' '箚뙻 Lock' '箚뿼 Logout' '箚쐣 Reboot' '箚맓 Power off' '箚뀟 Cancel' | rofi -dmenu -i -p 'Power' -theme "$theme" || true)"

case "$choice" in
  *'Lock') exec hyprlock ;;
  *'Logout') hyprctl dispatch exit ;;
  *'Reboot') systemctl reboot ;;
  *'Power off') systemctl poweroff ;;
  *) exit 0 ;;
esac
