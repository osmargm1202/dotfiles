#!/usr/bin/env bash
set -euo pipefail

theme="${HYPR_ROFI_THEME:-$HOME/.config/rofi/hypr-menu.rasi}"
choice="$(printf '%s\n' '箚뙻 Lock' '箚뿼 Logout' '箚쐣 Reboot' '箚맓 Power off' '箚뀟 Cancel' \
  | rofi -dmenu -i -p 'Power' -theme "$theme" \
      -theme-str 'window { width: 360px; } listview { lines: 5; } element { padding: 5px 8px; } element-icon { size: 22px; } inputbar { padding: 8px; }' \
  || true)"

case "$choice" in
  *'Lock') exec "$HOME/.local/bin/hypr-lock" ;;
  *'Logout') hyprctl dispatch exit ;;
  *'Reboot') systemctl reboot ;;
  *'Power off') systemctl poweroff ;;
  *) exit 0 ;;
esac
