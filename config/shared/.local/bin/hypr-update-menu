#!/usr/bin/env bash
set -euo pipefail

theme="${HYPR_ROFI_THEME:-$HOME/.config/rofi/hypr-menu.rasi}"
repo="${DOTFILES_REPO:-$HOME/Hobby/dotfiles}"
host="${HYPR_HOST:-$(hostname)}"
profile="${HYPR_PROFILE:-hyprland}"
target="${HYPR_UPDATE_TARGET:-$host-$profile}"
status_bin="${HYPR_UPDATE_STATUS_BIN:-$HOME/.local/bin/hypr-update-status}"
# Terminal must accept kitty-compatible flags: --class, -T, -e.
terminal="${HYPR_KITTY:-${HYPR_TERMINAL:-kitty}}"

pick() {
  rofi -dmenu -i -show-icons -p "$1" -theme "$theme"
}

run_terminal() {
  local title="$1"
  shift
  exec "$terminal" --class hypr-update -T "$title" -e "$@"
}

child_check_script() {
  cat <<'SCRIPT'
status_bin=${HYPR_UPDATE_STATUS_BIN:-}
if [ -n "$status_bin" ] && [ -x "$status_bin" ]; then
  "$status_bin" force
  force_rc=$?
  echo
  "$status_bin" summary || true
else
  printf '%s\n' "hypr-update-status not installed or not executable: ${status_bin:-<unset>}"
  force_rc=127
fi
echo
printf '%s' 'press enter...'
read -r _ || true
exit "$force_rc"
SCRIPT
}

child_update_script() {
  cat <<'SCRIPT'
label=${HYPR_UPDATE_LABEL:-Update}
status_bin=${HYPR_UPDATE_STATUS_BIN:-}

notify-send 'ORGM Update' "$label started" 2>/dev/null || true

run_update() {
  case "${HYPR_UPDATE_ACTION:-}" in
    nixos)
      cd "$DOTFILES_REPO" && nh os switch ".#$HYPR_UPDATE_TARGET" --update
      ;;
    flatpak)
      flatpak update
      ;;
    distrobox-arch)
      distrobox-enter arch -- fish -lc 'paru -Syu'
      ;;
    pi)
      distrobox-enter arch -- fish -lc 'fnm env --shell fish | source; pi update || npm i -g @earendil-works/pi-coding-agent'
      ;;
    *)
      printf '%s\n' "Unknown update action: ${HYPR_UPDATE_ACTION:-<unset>}" >&2
      return 64
      ;;
  esac
}

run_update
rc=$?

if [ "$rc" -eq 0 ]; then
  notify-send 'ORGM Update' "$label finished" 2>/dev/null || true
else
  notify-send -u critical 'ORGM Update' "$label failed" 2>/dev/null || true
fi

if [ -n "$status_bin" ] && [ -x "$status_bin" ]; then
  "$status_bin" force >/dev/null 2>&1 || true
fi

echo
printf '%s' 'press enter...'
read -r _ || true
exit "$rc"
SCRIPT
}

run_check_now() {
  run_terminal 'Check updates' \
    env "HYPR_UPDATE_STATUS_BIN=$status_bin" \
    sh -lc "$(child_check_script)"
}

run_update_terminal() {
  local title="$1" label="$2" action="$3"
  run_terminal "$title" \
    env \
      "HYPR_UPDATE_LABEL=$label" \
      "HYPR_UPDATE_ACTION=$action" \
      "HYPR_UPDATE_STATUS_BIN=$status_bin" \
      "DOTFILES_REPO=$repo" \
      "HYPR_UPDATE_TARGET=$target" \
    sh -lc "$(child_update_script)"
}

show_status() {
  local summary
  if [ -x "$status_bin" ]; then
    summary="$($status_bin summary 2>/dev/null || true)"
  else
    summary="hypr-update-status not installed yet"
  fi
  printf '%s\n' "$summary" "" "Check now" "Back" | pick 'Update Status' || true
}

main_choice="$(printf '%s\n' \
  'ůįúČ Status' \
  'ůįĎď Check now' \
  'ÔĆď NixOS host' \
  'ůįŹĖ Flatpak' \
  'ÔĆÉ Distrobox Arch packages' \
  'ůįö© Pi coding agent' \
  'ůįÖĖ Cancel' | pick 'Updates' || true)"

case "$main_choice" in
  *'Status')
    choice="$(show_status)"
    case "$choice" in
      'Check now') run_check_now ;;
      *) exit 0 ;;
    esac
    ;;
  *'Check now')
    run_check_now
    ;;
  *'NixOS host')
    run_update_terminal 'NixOS update' "NixOS $target" 'nixos'
    ;;
  *'Flatpak')
    run_update_terminal 'Flatpak update' 'Flatpak' 'flatpak'
    ;;
  *'Distrobox Arch packages')
    run_update_terminal 'Distrobox Arch update' 'Distrobox Arch' 'distrobox-arch'
    ;;
  *'Pi coding agent')
    run_update_terminal 'Pi update' 'Pi coding agent' 'pi'
    ;;
  *'Cancel'|'')
    exit 0
    ;;
esac
