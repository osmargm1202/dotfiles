#!/usr/bin/env bash
set -euo pipefail

lib="${HYPR_ROFI_LIB:-$HOME/.local/bin/hypr-rofi-lib}"
# shellcheck disable=SC1090
. "$lib"

mode="${1:-status}"

has_battery() {
  ls /sys/class/power_supply/BAT* >/dev/null 2>&1
}

profile_icon() {
  case "$1" in
    performance) printf "󰓅" ;;
    balanced)    printf "󰁿" ;;
    power-saver) printf "󱡴" ;;
    *)           printf "󰁿" ;;
  esac
}

case "$mode" in
  check)
    has_battery
    ;;
  status)
    has_battery || exit 0
    current="$(powerprofilesctl get 2>/dev/null || echo "balanced")"
    icon="$(profile_icon "$current")"
    printf '{"text":"%s %s","tooltip":"Power profile: %s\\nClick to change","class":"power-profile-%s"}\n' \
      "$icon" "$current" "$current" "$current"
    ;;
  pick)
    has_battery || exit 0
    choices=(
      "$(profile_icon performance) performance"
      "$(profile_icon balanced) balanced"
      "$(profile_icon power-saver) power-saver"
    )
    selected="$(printf '%s\n' "${choices[@]}" | hypr_rofi_dmenu 'Power Profile' 3 || true)"
    [ -z "$selected" ] && exit 0
    profile="${selected##* }"
    [ -n "$profile" ] && powerprofilesctl set "$profile"
    ;;
  *)
    printf 'Usage: waybar-power-profile <check|status|pick>\n' >&2
    exit 2
    ;;
esac
