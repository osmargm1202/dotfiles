#!/bin/sh

if ! command -v yad >/dev/null 2>&1; then
  notify-send "Sway keybindings" "yad no está instalado. Rebuild NixOS para activar pkgs.yad." 2>/dev/null || true
  exit 1
fi

exec yad \
  --title="Sway-WM keybindings" \
  --no-buttons \
  --geometry=560x520-15-400 \
  --list \
  --column="key:" \
  --column="description:" \
  --column="command:" \
  "ESC" "cerrar esta ayuda" "" \
  "Win" "modkey" "Mod4" \
  "Win+/" "ayuda de atajos" "sway-keybindings-help" \
  "Win+Enter" "Terminal" "kitty" \
  "Win+Shift+Enter" "Terminal Arch distrobox" "kitty -e distrobox-enter arch" \
  "Win+D / Win+Space" "Application Menu" "fuzzel" \
  "Win+E" "Archivos" "nautilus" \
  "Win+W" "Browser" "Zen Browser" \
  "Win+Q" "Cerrar app enfocada" "kill" \
  "Win+V" "Clipboard" "cliphist + fuzzel" \
  "Win+Alt+E" "Power menu" "wlogout" \
  "Win+Alt+L" "Lock" "swaylock" \
  "Win+N" "Notificaciones" "swaync" \
  "Win+P" "Pantallas" "wdisplays" \
  "Ctrl+Space" "Cambiar teclado" "US / LATAM" \
  "Print" "Screenshot" "grim/slurp/swappy" \
  "Win+Shift+W" "Cambiar wallpaper" "sway-random-wallpaper" \
  "Win+Shift+/" "Nuevo tmux zellij" "tmuxnewz" \
  "Win+Ctrl+/" "Lista tmux" "tmuxls"
