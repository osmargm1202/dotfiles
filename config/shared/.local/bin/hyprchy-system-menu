#!/usr/bin/env bash
set -euo pipefail

theme="${HYPRCHY_ROFI_THEME:-$HOME/.config/rofi-hyprchy/control-center.rasi}"
repo="${HYPRCHY_DOTFILES:-$HOME/Hobby/dotfiles}"
host="${HYPRCHY_HOST:-$(hostname)}"
choice="$(printf '%s\n' '󱄅 NixOS build hyprchy' '󰑓 NixOS test hyprchy' '󰁯 dot.sh status' '󰕚 dot.sh diff' '󰑓 dot.sh sync' '󰆍 Logs' '󰅖 Cancel' | rofi -dmenu -i -p 'System' -theme "$theme" || true)"

case "$choice" in
  *'build hyprchy') exec kitty --class hyprchy-build -e sh -lc "cd '$repo' && nh os build . --hostname ${host}-hyprchy; read -r -p 'press enter...'" ;;
  *'test hyprchy') exec kitty --class hyprchy-test -e sh -lc "cd '$repo' && nh os test . --hostname ${host}-hyprchy; read -r -p 'press enter...'" ;;
  *'dot.sh status') exec kitty --class dotfiles-status -e sh -lc "cd '$repo' && ./dot.sh status --host '$host'; read -r -p 'press enter...'" ;;
  *'dot.sh diff') exec kitty --class dotfiles-diff -e sh -lc "cd '$repo' && ./dot.sh diff --host '$host'; read -r -p 'press enter...'" ;;
  *'dot.sh sync') exec kitty --class dotfiles-sync -e sh -lc "cd '$repo' && ./dot.sh sync --host '$host'; read -r -p 'press enter...'" ;;
  *'Logs') exec kitty --class hyprchy-logs -e journalctl --user -n 200 --no-pager ;;
  *) exit 0 ;;
esac
