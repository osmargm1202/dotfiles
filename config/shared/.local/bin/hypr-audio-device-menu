#!/usr/bin/env bash
set -euo pipefail

mode="${1:-}"
case "$mode" in
  output)
    section="Sinks"
    prompt="Audio output"
    ;;
  input)
    section="Sources"
    prompt="Audio input"
    ;;
  *)
    echo "usage: hypr-audio-device-menu output|input" >&2
    exit 2
    ;;
esac

wpctl_cmd="${HYPR_AUDIO_WPCTL:-wpctl}"

list_devices() {
  "$wpctl_cmd" status | awk -v section="$section" '
    $0 ~ "^[[:space:]│├└─]*" section ":" { in_section = 1; next }
    in_section && $0 ~ "^[[:space:]│├└─]*[A-Za-z]+:" { exit }
    in_section && match($0, /^[[:space:]│*]*([0-9]+)\. (.*) \[/, m) {
      print m[1] "\t" m[2]
    }
  '
}

pick_device() {
  if [ -n "${HYPR_AUDIO_DMENU_CMD:-}" ]; then
    "$HYPR_AUDIO_DMENU_CMD"
    return
  fi

  local lib="${HYPR_ROFI_LIB:-$HOME/.local/bin/hypr-rofi-lib}"
  # shellcheck disable=SC1090
  . "$lib"
  hypr_rofi_dmenu "$prompt" 10 "${HYPR_ROFI_AUDIO_WIDTH:-$HYPR_ROFI_WIDTH}"
}

selection="$(list_devices | pick_device || true)"
[ -n "${selection:-}" ] || exit 0
id="${selection%%$'\t'*}"

if ! [[ "$id" =~ ^[0-9]+$ ]]; then
  notify-send "Audio" "Selección inválida: $selection" 2>/dev/null || true
  exit 1
fi

"$wpctl_cmd" set-default "$id"
notify-send "Audio" "Default $prompt: ${selection#*$'\t'}" 2>/dev/null || true
