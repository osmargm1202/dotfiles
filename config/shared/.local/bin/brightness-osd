#!/bin/sh

case "${1:-}" in
  up) brightnessctl set 5%+ >/dev/null ;;
  down) brightnessctl set 5%- >/dev/null ;;
  *) echo "usage: brightness-osd up|down" >&2; exit 2 ;;
esac

pct=$(brightnessctl -m 2>/dev/null | awk -F, '{ gsub(/%/, "", $4); print $4 }')
pct=${pct:-0}

if command -v notify-send >/dev/null 2>&1; then
  notify-send -a "osd-brightness" \
    -h string:x-canonical-private-synchronous:osd-brightness \
    -h int:value:"$pct" \
    -t 900 \
    "󰃠 Brightness ${pct}%" "" >/dev/null 2>&1 || true
fi
