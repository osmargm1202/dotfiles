#!/usr/bin/env bash
set -euo pipefail

theme="${HYPRCHY_ROFI_THEME:-$HOME/.config/rofi-hyprchy/control-center.rasi}"
choice="$(printf '%s\n' '󰖔 Dark mode' '󰖨 Light mode' '󰸉 Wallpaper menu' '󰏘 Reload UI' '󰅖 Cancel' | rofi -dmenu -i -p 'Appearance' -theme "$theme" || true)"

case "$choice" in
  *'Dark mode') gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark' ;;
  *'Light mode') gsettings set org.gnome.desktop.interface color-scheme 'prefer-light' ;;
  *'Wallpaper menu') exec hyprchy-wallpaper-menu ;;
  *'Reload UI') hyprctl reload; hyprpanel -q 2>/dev/null || true; hyprpanel >/dev/null 2>&1 & ;;
  *) exit 0 ;;
esac
