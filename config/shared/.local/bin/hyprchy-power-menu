#!/usr/bin/env bash
set -euo pipefail

choice="$(printf '%s\n' '箚뙻 Lock' '箚뿼 Logout' '箚쐣 Reboot' '箚맓 Power off' '箚뀟 Cancel' | rofi -dmenu -i -p 'Power' -theme "${HYPRCHY_ROFI_THEME:-$HOME/.config/rofi-hyprchy/control-center.rasi}" || true)"

case "$choice" in
  *'Lock') exec hyprlock ;;
  *'Logout') hyprctl dispatch exit ;;
  *'Reboot') systemctl reboot ;;
  *'Power off') systemctl poweroff ;;
  *) exit 0 ;;
esac
