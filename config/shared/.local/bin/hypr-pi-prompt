#!/bin/sh
set -eu

launcher="fuzzel"
input=""
while [ "$#" -gt 0 ]; do
  case "$1" in
    --launcher) launcher="${2:-fuzzel}"; shift 2 ;;
    --input) input="${2:-}"; shift 2 ;;
    *) shift ;;
  esac
done

if [ -z "$input" ]; then
  case "$launcher" in
    rofi) input="$(printf '' | rofi -dmenu -p 'Pedir instrucción a Pi' || true)" ;;
    walker) input="$(printf '' | walker --dmenu --placeholder 'Pedir instrucción a Pi' || true)" ;;
    *) input="$(printf '' | fuzzel --dmenu --prompt 'Pedir instrucción a Pi> ' || true)" ;;
  esac
fi

[ -n "$input" ] || exit 0
exec kitty --class kitty --hold -e distrobox-enter arch -- pi "$input"
