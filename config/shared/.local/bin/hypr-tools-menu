#!/usr/bin/env bash
set -euo pipefail

lib="${HYPR_ROFI_LIB:-$HOME/.local/bin/hypr-rofi-lib}"
# shellcheck disable=SC1090
. "$lib"

choice="$(printf '%s\n' '箚냽 Terminal' '箚뎸 Files' '箚뜆 Search files' '箚꺆 Calculator' '箚뜾 Displays' '箚툒 Wallpaper next' '箚뀟 Cancel' | hypr_rofi_dmenu 'Tools' || true)"

case "$choice" in
  *'Terminal') exec kitty ;;
  *'Files') exec nautilus ;;
  *'Search files') exec ~/.local/bin/hypr-rofi-open-file ;;
  *'Calculator') exec ~/.local/bin/hypr-rofi-calc ;;
  *'Displays') exec nwg-displays ;;
  *'Wallpaper') exec ~/.local/bin/hypr-random-wallpaper next ;;
  *) exit 0 ;;
esac
