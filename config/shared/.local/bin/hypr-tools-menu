#!/usr/bin/env bash
set -euo pipefail

lib="${HYPR_ROFI_LIB:-$HOME/.local/bin/hypr-rofi-lib}"
# shellcheck disable=SC1090
. "$lib"

choice="$(printf '%s\n' '¾░åì Terminal' '¾░ëï Files' '¾░ìë Search files' '¯ÿò Hypr config' '¾░â¡ Calculator' '¾░ì╣ Displays' '¾░©ë Wallpaper next' '¾░àû Cancel' | hypr_rofi_dmenu 'Tools' || true)"

case "$choice" in
  *'Terminal') exec kitty ;;
  *'Files') exec nautilus ;;
  *'Search files') exec ~/.local/bin/hypr-rofi-open-file ;;
  *'Hypr config') exec ~/.local/bin/hypr-config-editor ;;
  *'Calculator') exec ~/.local/bin/hypr-rofi-calc ;;
  *'Displays') exec nwg-displays ;;
  *'Wallpaper') exec ~/.local/bin/hypr-random-wallpaper next ;;
  *) exit 0 ;;
esac
