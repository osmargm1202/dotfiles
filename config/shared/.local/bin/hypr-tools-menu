#!/usr/bin/env bash
set -euo pipefail

theme="${HYPR_ROFI_THEME:-$HOME/.config/rofi/hypr-menu.rasi}"
choice="$(printf '%s\n' '箚냽 Terminal' '箚뎸 Files' '箚뜆 Search files' '箚꺆 Calculator' '箚뜾 Displays' '箚툒 Wallpaper next' '箚뀟 Cancel' | rofi -dmenu -i -p 'Tools' -theme "$theme" || true)"

case "$choice" in
  *'Terminal') exec kitty ;;
  *'Files') exec nautilus ;;
  *'Search files') exec ~/.local/bin/fuzzel-open-file ;;
  *'Calculator') exec gnome-calculator ;;
  *'Displays') exec nwg-displays ;;
  *'Wallpaper') exec orgm-hypr wallpaper next ;;
  *) exit 0 ;;
esac
