#!/usr/bin/env bash
set -euo pipefail

lib="${HYPR_ROFI_LIB:-$HOME/.local/bin/hypr-rofi-lib}"
# shellcheck disable=SC1090
. "$lib"

choice="$(printf '%s\n' \
  '¾░åı Terminal' \
  '¾░åı Terminal Arch' \
  '¾░ëï Files' \
  '¾░ıë Search files' \
  '´â¬ Clipboard' \
  '¯İò Hypr config' \
  '¾░â¡ Calculator' \
  '¾░úå Web App Maker' \
  '¾░àû Cancel' | hypr_rofi_dmenu 'Tools' || true)"

case "$choice" in
  *'Terminal Arch') exec kitty -e distrobox-enter arch ;;
  *'Terminal') exec kitty ;;
  *'Files') exec nautilus ;;
  *'Search files') exec hypr-rofi-open-file ;;
  *'Clipboard') exec hypr-rofi-clipboard ;;
  *'Hypr config') exec hypr-config-editor ;;
  *'Calculator') exec hypr-rofi-calc ;;
  *'Web App Maker') exec hypr-webapp-maker ;;
  *) exit 0 ;;
esac
