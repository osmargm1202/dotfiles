#!/bin/sh
set -eu

wallpaper_dir="${HOME}/Pictures/Wallpapers"
fallback="${HOME}/.config/wallpapers/xnm1-background.png"
interval="${HYPR_WALLPAPER_INTERVAL:-3600}"
state_dir="${XDG_RUNTIME_DIR:-/tmp}"
current_file="${state_dir}/hypr-random-wallpaper.current"
lock_wallpaper="${state_dir}/hypr-current-wallpaper"
daemon_pid_file="${state_dir}/hypr-random-wallpaper.daemon.pid"
hyprpaper_conf="${state_dir}/hypr-random-wallpaper.hyprpaper.conf"

resolve_hyprpaper() {
  if [ -n "${HYPRPAPER_BIN:-}" ] && [ -x "${HYPRPAPER_BIN}" ]; then
    printf '%s\n' "${HYPRPAPER_BIN}"
  elif command -v hyprpaper >/dev/null 2>&1; then
    command -v hyprpaper
  elif [ -x /run/current-system/sw/bin/hyprpaper ]; then
    printf '%s\n' /run/current-system/sw/bin/hyprpaper
  else
    printf '%s\n' hyprpaper
  fi
}

hyprpaper_bin="$(resolve_hyprpaper)"

mkdir -p "${wallpaper_dir}"

pick_wallpaper() {
  find "${wallpaper_dir}" -type f \( \
    -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.png' -o -iname '*.webp' \
  \) | shuf -n 1
}

write_hyprpaper_config() {
  wallpaper="$1"
  cat >"${hyprpaper_conf}" <<EOF
wallpaper {
    monitor =
    path = ${wallpaper}
    fit_mode = cover
}
EOF
}

restart_hyprpaper() {
  if command -v "${hyprpaper_bin}" >/dev/null 2>&1 || [ -x "${hyprpaper_bin}" ]; then
    pkill -x hyprpaper >/dev/null 2>&1 || true
    "${hyprpaper_bin}" -c "${hyprpaper_conf}" >/tmp/hyprpaper.log 2>&1 &
  elif command -v distrobox-host-exec >/dev/null 2>&1; then
    distrobox-host-exec sh -lc "pkill -x hyprpaper >/dev/null 2>&1 || true; hyprpaper -c '$hyprpaper_conf' >/tmp/hyprpaper.log 2>&1 &"
  else
    echo "hyprpaper not found" >&2
    return 1
  fi
  sleep 1
}

set_wallpaper() {
  wallpaper="$(pick_wallpaper || true)"
  if [ -z "${wallpaper}" ]; then
    wallpaper="${fallback}"
  fi

  if [ ! -f "${wallpaper}" ]; then
    echo "Wallpaper not found: ${wallpaper}" >&2
    return 1
  fi

  write_hyprpaper_config "${wallpaper}"
  restart_hyprpaper
  printf '%s\n' "${wallpaper}" > "${current_file}"
  ln -sfn "${wallpaper}" "${lock_wallpaper}"
}

case "${1:-daemon}" in
  next|change)
    set_wallpaper
    ;;
  daemon)
    for old_daemon in $(pgrep -f "^/bin/sh ${HOME}/.local/bin/hypr-random-wallpaper" 2>/dev/null || true); do
      if [ "${old_daemon}" != "$$" ] && kill -0 "${old_daemon}" 2>/dev/null; then
        kill -KILL "${old_daemon}" 2>/dev/null || true
      fi
    done

    if [ -f "${daemon_pid_file}" ]; then
      old_daemon="$(cat "${daemon_pid_file}" 2>/dev/null || true)"
      if [ -n "${old_daemon}" ] && [ "${old_daemon}" != "$$" ] && kill -0 "${old_daemon}" 2>/dev/null; then
        kill -KILL "${old_daemon}" 2>/dev/null || true
      fi
    fi

    printf '%s\n' "$$" > "${daemon_pid_file}"
    while true; do
      set_wallpaper
      sleep "${interval}"
    done
    ;;
  *)
    echo "usage: hypr-random-wallpaper [daemon|next]" >&2
    exit 2
    ;;
esac
