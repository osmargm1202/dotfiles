#!/bin/sh
set -eu

cd "$HOME"

selection=$(
  find . -type f \
    -not -path '*/.*/*' \
    -not -path './.*' \
    -not -path './go/*' \
    -not -path './paru/*' \
    -not -path '*/node_modules/*' \
    -not -path '*/target/*' \
    -printf '%T@\t%P\n' 2>/dev/null \
    | sort -rn \
    | cut -f2- \
    | hypr-dmenu --prompt "Term dir> "
)

[ -n "${selection:-}" ] || exit 0
dir=$(dirname "$HOME/$selection")
exec kitty --directory "$dir"
