#!/usr/bin/env bash
set -euo pipefail

lib="${HYPR_ROFI_LIB:-$HOME/.local/bin/hypr-rofi-lib}"
# shellcheck disable=SC1090
. "$lib"

bin_dir="${HYPR_BIN_DIR:-$HOME/.local/bin}"

choice="$(printf '%s\n' \
  'َ°€» Apps' \
  'َ°’“ Tools' \
  'َ±گ‹ Performance' \
  'َ°–© WiFi' \
  'َ°‚¯ Bluetooth' \
  'َ°چ‰ Search' \
  'َ°ŒŒ Keybinds' \
  'َ°”ژ Theme' \
  'َ°’“ System' \
  'َ°گ¥ Power' \
  'َ°ŒŒ Keyboard' \
  'َ°£† Web App Maker' \
  'َ°…– Quit' | hypr_rofi_dmenu 'Hyprland' || true)"

case "$choice" in
  *'Apps') hypr_rofi_drun; exit $? ;;
  *'Tools') exec "$bin_dir/hypr-tools-menu" ;;
  *'Performance') exec "$bin_dir/hypr-performance-menu" ;;
  *'WiFi') exec "$bin_dir/hypr-wifi-menu" ;;
  *'Bluetooth') exec "$bin_dir/hypr-bluetooth-menu" ;;
  *'Search') exec "$bin_dir/hypr-smart-run" ;;
  *'Keybinds') exec "$bin_dir/hypr-keybindings-help" ;;
  *'Theme') exec "$bin_dir/hypr-theme-chooser" ;;
  *'System') exec "$bin_dir/hypr-system-menu" ;;
  *'Power') exec "$bin_dir/hypr-power-menu" ;;
  *'Keyboard') exec "$bin_dir/hypr-keyboard-menu" ;;
  *'Web App Maker') exec "$bin_dir/hypr-webapp-maker" ;;
  *'Quit'|'') exit 0 ;;
esac
