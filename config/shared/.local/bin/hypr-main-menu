#!/usr/bin/env bash
set -euo pipefail

theme="${HYPR_ROFI_THEME:-$HOME/.config/rofi/hypr-menu.rasi}"
bin_dir="${HYPR_BIN_DIR:-$HOME/.local/bin}"
repo="${HYPR_DOTFILES_REPO:-$HOME/Hobby/dotfiles}"
host="${HYPR_DOT_HOST:-$(hostname -s)}"
target="${HYPR_NIXOS_TARGET:-${host}-hyprland}"

pick() {
  rofi -dmenu -i -show-icons -p "$1" -theme "$theme"
}

choice="$(cat <<'EOF_MENU' | pick 'Hyprland'
¾░Ć╗ Apps
¾░Æō Tools
¾░åŹ Tools / Terminal
¾░ēŗ Tools / Files
¾░Źē Tools / Search files
¾░āŁ Tools / Calculator
¾░Ź╣ Tools / Displays
¾░Ėē Tools / Wallpaper next
¾░Ü░ Update
¾░Ü░ Update / NixOS switch
¾░ēŗ Update / Open repo
¾▒Éŗ Performance
¾░Źø Performance / btop
¾░Źø Performance / htop
¾░Źø Performance / dgop
¾░Źø Performance / GNOME System Monitor
¾░¢® WiFi
¾░é» Bluetooth
¾░Źē Search
¾░īī Keybinds
¾░Æō System
¾░æō System / Reload Hyprland
¾░æō System / Restart Waybar
¾░åŹ System / User logs
¾░ü» System / dot.sh status
¾░ĢÜ System / dot.sh diff
¾░æō System / dot.sh sync
¾░ēŗ System / Open dotfiles
¾░Éź Power
¾░īŠ Power / Lock
¾░Ś╝ Power / Logout
¾░£ē Power / Reboot
¾░Éź Power / Power off
¾░īī Keyboard
¾░īī Keyboard / Toggle layout
¾░īī Keyboard / US
¾░īī Keyboard / Latam
¾░Żå Web App Maker
¾░ģ¢ Quit
EOF_MENU
)"

case "$choice" in
  '¾░Ć╗ Apps') exec rofi -show drun -theme "$theme" ;;
  '¾░Æō Tools') exec "$bin_dir/hypr-tools-menu" ;;
  *'Tools / Terminal') exec kitty ;;
  *'Tools / Files') exec nautilus ;;
  *'Tools / Search files') exec "$bin_dir/fuzzel-open-file" ;;
  *'Tools / Calculator') exec gnome-calculator ;;
  *'Tools / Displays') exec nwg-displays ;;
  *'Tools / Wallpaper next') exec "$bin_dir/hypr-random-wallpaper" next ;;
  '¾░Ü░ Update') exec "$bin_dir/hypr-update-menu" ;;
  *'Update / NixOS switch') exec kitty --class hypr-update -e sh -lc "cd '$repo' && nh os switch .#$target --update; read -r -p 'press enter...'" ;;
  *'Update / Open repo') exec nautilus "$repo" ;;
  '¾▒Éŗ Performance') exec "$bin_dir/hypr-performance-menu" ;;
  *'Performance / btop') exec kitty -e btop ;;
  *'Performance / htop') exec kitty -e htop ;;
  *'Performance / dgop') exec kitty -e dgop ;;
  *'Performance / GNOME System Monitor') exec gnome-system-monitor ;;
  '¾░¢® WiFi') exec "$bin_dir/hypr-wifi-menu" ;;
  '¾░é» Bluetooth') exec "$bin_dir/hypr-bluetooth-menu" ;;
  '¾░Źē Search') exec "$bin_dir/hypr-smart-run" ;;
  '¾░īī Keybinds') exec "$bin_dir/hypr-keybindings-help" ;;
  '¾░Æō System') exec "$bin_dir/hypr-system-menu" ;;
  *'System / Reload Hyprland') exec hyprctl reload ;;
  *'System / Restart Waybar') pkill waybar 2>/dev/null || true; exec waybar -c ~/.config/waybar-hypr/config -s ~/.config/waybar-hypr/style.css ;;
  *'System / User logs') exec kitty --class user-logs -e journalctl --user -n 200 --no-pager ;;
  *'System / dot.sh status') exec kitty --class dot-status -e sh -lc "cd '$repo' && ./dot.sh status --host '$host'; read -r -p 'press enter...'" ;;
  *'System / dot.sh diff') exec kitty --class dot-diff -e sh -lc "cd '$repo' && ./dot.sh diff --host '$host'; read -r -p 'press enter...'" ;;
  *'System / dot.sh sync') exec kitty --class dot-sync -e sh -lc "cd '$repo' && ./dot.sh sync --host '$host'; read -r -p 'press enter...'" ;;
  *'System / Open dotfiles') exec nautilus "$repo" ;;
  '¾░Éź Power') exec "$bin_dir/hypr-power-menu" ;;
  *'Power / Lock') exec "$bin_dir/hypr-lock" ;;
  *'Power / Logout') exec hyprctl dispatch exit ;;
  *'Power / Reboot') exec systemctl reboot ;;
  *'Power / Power off') exec systemctl poweroff ;;
  '¾░īī Keyboard') exec "$bin_dir/hypr-keyboard-menu" ;;
  *'Keyboard / Toggle layout') exec hyprctl switchxkblayout all next ;;
  *'Keyboard / US') exec hyprctl keyword input:kb_layout us ;;
  *'Keyboard / Latam') exec hyprctl keyword input:kb_layout latam ;;
  '¾░Żå Web App Maker') exec "$bin_dir/hypr-webapp-maker" ;;
  '¾░ģ¢ Quit'|'') exit 0 ;;
esac
