#!/usr/bin/env bash
set -euo pipefail

browser="${BROWSER:-chromium}"
theme="${HYPR_ROFI_THEME:-$HOME/.config/rofi/hypr-menu.rasi}"
menu=$'!a ChatGPT\n!c Claude\n!g Google\n!y YouTube'

input="${*:-}"
if [ -z "$input" ]; then
  input="$(printf '%s\n' "$menu" | rofi -dmenu -i -p 'Search or URL' -mesg 'Hints: !a ChatGPT | !c Claude | !g Google | !y YouTube' -theme "$theme" || true)"
fi

input="$(printf '%s' "$input" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
[ -n "$input" ] || exit 0

open_url() { nohup "$browser" "$1" >/dev/null 2>&1 & }
search_url() { local engine="$1" q="$2"; q="${q// /+}"; open_url "$engine$q"; }
launch_desktop() {
  local desktop="$1" query="${2:-}"
  if [ -n "$query" ] && command -v wl-copy >/dev/null 2>&1; then
    printf '%s' "$query" | wl-copy || true
  fi
  if command -v gio >/dev/null 2>&1; then
    gio launch "$HOME/.local/share/applications/$desktop" >/dev/null 2>&1 &
  else
    nohup gtk-launch "${desktop%.desktop}" >/dev/null 2>&1 &
  fi
}

case "$input" in
  http://*|https://*) open_url "$input" ;;
  localhost:*|127.0.0.1:*) open_url "http://$input" ;;
  *'!a'*) launch_desktop 'Chatgpt.desktop' "$(printf '%s' "${input//!a/}" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')" ;;
  *'!c'*) launch_desktop 'Claude.desktop' "$(printf '%s' "${input//!c/}" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')" ;;
  *'!g'*) search_url 'https://www.google.com/search?q=' "${input//!g/}" ;;
  *'!y'*) search_url 'https://www.youtube.com/results?search_query=' "${input//!y/}" ;;
  *)
    if [[ "$input" != *' '* ]] && command -v "$input" >/dev/null 2>&1; then
      nohup "$input" >/dev/null 2>&1 &
    elif [[ "$input" != *' '* ]] && [[ "$input" =~ ^[A-Za-z0-9.-]+\.[A-Za-z]{2,}(/.*)?$ ]]; then
      open_url "https://$input"
    else
      launch_desktop 'Chatgpt.desktop' "$input"
    fi
    ;;
esac
