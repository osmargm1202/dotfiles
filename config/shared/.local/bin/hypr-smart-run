#!/usr/bin/env bash
set -euo pipefail

browser="${BROWSER:-chromium}"
theme="${HYPR_ROFI_THEME:-$HOME/.config/rofi/hypr-menu.rasi}"
menu=$'!g Google\n!d DuckDuckGo\n!y YouTube'

input="${*:-}"
if [ -z "$input" ]; then
  input="$(printf '%s\n' "$menu" | rofi -dmenu -i -p 'Search or URL' -mesg 'Hints: !g Google | !d DuckDuckGo | !y YouTube' -theme "$theme" || true)"
fi

input="$(printf '%s' "$input" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
[ -n "$input" ] || exit 0

open_url() { nohup "$browser" "$1" >/dev/null 2>&1 & }
search_url() { local engine="$1" q="$2"; q="${q// /+}"; open_url "$engine$q"; }

case "$input" in
  http://*|https://*) open_url "$input" ;;
  localhost:*|127.0.0.1:*) open_url "http://$input" ;;
  *'!g'*) search_url 'https://www.google.com/search?q=' "${input//!g/}" ;;
  *'!y'*) search_url 'https://www.youtube.com/results?search_query=' "${input//!y/}" ;;
  *'!d'*) search_url 'https://duckduckgo.com/?q=' "${input//!d/}" ;;
  *)
    if [[ "$input" != *' '* ]] && command -v "$input" >/dev/null 2>&1; then
      nohup "$input" >/dev/null 2>&1 &
    elif [[ "$input" != *' '* ]] && [[ "$input" =~ ^[A-Za-z0-9.-]+\.[A-Za-z]{2,}(/.*)?$ ]]; then
      open_url "https://$input"
    else
      search_url 'https://duckduckgo.com/?q=' "$input"
    fi
    ;;
esac
