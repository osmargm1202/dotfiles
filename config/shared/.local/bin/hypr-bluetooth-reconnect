#!/usr/bin/env bash
set -euo pipefail

notify() {
  notify-send "USB headset reconnect" "$1" 2>/dev/null || true
}

cmd="${HYPR_HEADSET_RECONNECT_CMD:-unbindheadset}"

if command -v kitty >/dev/null 2>&1; then
  kitty --title "USB headset reconnect" -e fish -lc "$cmd" &
  notify "Reconexión USB iniciada. Autoriza sudo si lo pide."
  exit 0
fi

if command -v fish >/dev/null 2>&1; then
  fish -lc "$cmd"
  notify "Reconexión USB completada."
  exit 0
fi

notify "fish no está instalado; no puedo ejecutar unbindheadset."
exit 1
