#!/bin/sh
set -eu

if command -v bluetui >/dev/null 2>&1; then
  exec kitty --class hyprchy-bluetooth -e bluetui
fi

if command -v blueman-manager >/dev/null 2>&1; then
  exec blueman-manager
fi

notify-send "Hyprchy Bluetooth" "No Bluetooth UI found: expected bluetui or blueman-manager" 2>/dev/null || true
