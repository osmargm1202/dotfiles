#!/usr/bin/env bash
set -euo pipefail

if ! command -v nwg-dock-hyprland >/dev/null 2>&1; then
  notify-send "Hyprland dock" "nwg-dock-hyprland is not installed yet" 2>/dev/null || true
  exit 1
fi

restart=0
if [ "${1:-}" = "reload" ] || [ "${1:-}" = "restart" ]; then
  restart=1
  pkill -f '^nwg-dock-hyprland( |$)' 2>/dev/null || true
  sleep 0.2
fi

if pgrep -f '^nwg-dock-hyprland( |$)' >/dev/null 2>&1; then
  [ "$restart" -eq 1 ] && exit 0
  exit 0
fi

exec nwg-dock-hyprland \
  -r \
  -p right \
  -a center \
  -i "${HYPR_NWG_DOCK_ICON_SIZE:-56}" \
  -x \
  -mr "${HYPR_NWG_DOCK_MARGIN_RIGHT:-8}" \
  -mt "${HYPR_NWG_DOCK_MARGIN_TOP:-0}" \
  -mb "${HYPR_NWG_DOCK_MARGIN_BOTTOM:-0}" \
  -c "${HYPR_NWG_DOCK_LAUNCHER:-$HOME/.local/bin/hypr-main-menu}"
