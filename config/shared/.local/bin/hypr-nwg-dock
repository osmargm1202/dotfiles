#!/usr/bin/env bash
set -euo pipefail

if ! command -v nwg-dock-hyprland >/dev/null 2>&1; then
  notify-send "Hyprland dock" "nwg-dock-hyprland is not installed yet" 2>/dev/null || true
  exit 1
fi

restart=0
if [ "${1:-}" = "reload" ] || [ "${1:-}" = "restart" ]; then
  restart=1
  pkill -f '^nwg-dock-hyprland( |$)' 2>/dev/null || true
  sleep 0.2
fi

if pgrep -f '^nwg-dock-hyprland( |$)' >/dev/null 2>&1; then
  [ "$restart" -eq 1 ] && exit 0
  exit 0
fi

dock_output_args=()
if command -v hypr-display-targets >/dev/null 2>&1; then
  dock_env="$(hypr-display-targets dock-env 2>/dev/null || true)"
  if [ -n "${dock_env:-}" ]; then
    read -r dock_flag dock_output <<<"$dock_env"
    if [ "$dock_flag" = "-o" ] && [ -n "${dock_output:-}" ]; then
      dock_output_args=(-o "$dock_output")
    fi
  fi
fi

exec nwg-dock-hyprland \
  "${dock_output_args[@]}" \
  -r \
  -p right \
  -a center \
  -i "${HYPR_NWG_DOCK_ICON_SIZE:-56}" \
  -x \
  -mr "${HYPR_NWG_DOCK_MARGIN_RIGHT:-8}" \
  -mt "${HYPR_NWG_DOCK_MARGIN_TOP:-0}" \
  -mb "${HYPR_NWG_DOCK_MARGIN_BOTTOM:-0}" \
  -lp "${HYPR_NWG_DOCK_LAUNCHER_POSITION:-start}" \
  -ico "${HYPR_NWG_DOCK_LAUNCHER_ICON:-$HOME/.local/share/icons/nixos.svg}" \
  -c "${HYPR_NWG_DOCK_LAUNCHER_COMMAND:-$HOME/.local/bin/hypr-app-launcher}"
