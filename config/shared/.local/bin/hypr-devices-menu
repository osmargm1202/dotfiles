#!/usr/bin/env bash
set -euo pipefail

lib="${HYPR_ROFI_LIB:-$HOME/.local/bin/hypr-rofi-lib}"
# shellcheck disable=SC1090
. "$lib"

choice="$(printf '%s\n' \
  'ó°–© WiFi' \
  'ó°‚Ż Bluetooth' \
  'ó°•“ USB devices' \
  'ó°•“ USB nicknames' \
  'ó°‹‹ Headset reconnect' \
  'ó°Ťą Displays' \
  'ď€¨ Audio output' \
  'ó°Ť¬ Audio input' \
  'ó°…– Cancel' | hypr_rofi_dmenu 'Devices' || true)"

case "$choice" in
  *'WiFi') exec hypr-wifi-menu ;;
  *'Bluetooth') exec hypr-bluetooth-menu ;;
  *'USB devices') exec hypr-usb-menu open ;;
  *'USB nicknames') exec hypr-usb-menu nickname ;;
  *'Headset reconnect') exec hypr-bluetooth-reconnect ;;
  *'Displays') exec hypr-display-targets menu ;;
  *'Audio output') exec hypr-audio-device-menu output ;;
  *'Audio input') exec hypr-audio-device-menu input ;;
  *) exit 0 ;;
esac
