#!/usr/bin/env bash
set -euo pipefail

lib="${HYPR_ROFI_LIB:-$HOME/.local/bin/hypr-rofi-lib}"
# shellcheck disable=SC1090
. "$lib"

repo="${DOTFILES_REPO:-$HOME/Hobby/dotfiles}"
host="${HYPR_HOST:-$(hostname)}"
choice="$(printf '%s\n' '󰑓 Reload Hyprland' '󰑓 Restart Waybar' '󰑓 Reload Dock' '󰆍 User logs' '󰁯 orgm-dot status' '󰕚 orgm-dot diff' '󰑓 orgm-dot sync' '󰉋 Open dotfiles' '󰅖 Cancel' | hypr_rofi_dmenu 'System' || true)"
case "$choice" in
  *'Reload Hyprland') exec hyprctl reload ;;
  *'Restart Waybar') exec waybar-watch ~/.config/waybar-hypr ;;
  *'Reload Dock') exec ~/.local/bin/hypr-nwg-dock reload ;;
  *'User logs') exec kitty --class user-logs -e journalctl --user -n 200 --no-pager ;;
  *'orgm-dot status') exec kitty --class dot-status -e sh -lc "cd '$repo' && distrobox-host-exec orgm-dot status; read -r -p 'press enter...'" ;;
  *'orgm-dot diff') exec kitty --class dot-diff -e sh -lc "cd '$repo' && distrobox-host-exec orgm-dot diff; read -r -p 'press enter...'" ;;
  *'orgm-dot sync') exec kitty --class dot-sync -e sh -lc "cd '$repo' && distrobox-host-exec orgm-dot sync; read -r -p 'press enter...'" ;;
  *'Open dotfiles') exec nautilus "$repo" ;;
  *) exit 0 ;;
esac
