#!/usr/bin/env bash
set -euo pipefail

lib="${HYPR_ROFI_LIB:-$HOME/.local/bin/hypr-rofi-lib}"
# shellcheck disable=SC1090
. "$lib"

repo="${DOTFILES_REPO:-$HOME/Hobby/dotfiles}"
orgm_themes_cmd() {
  if [ -x "$HOME/go/bin/orgm-themes" ]; then
    printf '%s\n' "$HOME/go/bin/orgm-themes"
  elif [ -x "$HOME/.local/bin/orgm-themes" ]; then
    printf '%s\n' "$HOME/.local/bin/orgm-themes"
  else
    command -v orgm-themes
  fi
}
theme_cmd="$(orgm_themes_cmd || true)"
choice="$(printf '%s\n' \
  '󰑓 Restart all' \
  '󰑓 Reload Hyprland' \
  '󰑓 Restart Waybar' \
  '󰑓 Reload Dock' \
  '󰔎 Theme light' \
  '󰔎 Theme dark' \
  '󰆍 User logs' \
  '󰁯 orgm-dot status' \
  '󰕚 orgm-dot diff' \
  '󰑓 orgm-dot sync' \
  '󰉋 Open dotfiles' \
  '󰐥 Power' \
  '󰅖 Cancel' | hypr_rofi_dmenu 'System' || true)"

case "$choice" in
  *'Restart all') exec sh -lc 'hyprctl reload >/dev/null 2>&1 || true; (waybar-watch ~/.config/waybar-hypr >/dev/null 2>&1 &); ~/.local/bin/hypr-nwg-dock reload >/dev/null 2>&1 || true' ;;
  *'Reload Hyprland') exec hyprctl reload ;;
  *'Restart Waybar') exec waybar-watch ~/.config/waybar-hypr ;;
  *'Reload Dock') exec ~/.local/bin/hypr-nwg-dock reload ;;
  *'Theme light') [ -n "$theme_cmd" ] && exec "$theme_cmd" apply orgm-light ;;
  *'Theme dark') [ -n "$theme_cmd" ] && exec "$theme_cmd" apply orgm-dark ;;
  *'User logs') exec kitty --class user-logs -e journalctl --user -n 200 --no-pager ;;
  *'orgm-dot status') exec kitty --class dot-status -e sh -lc "hypr-orgm-dot status; read -r -p 'press enter...'" ;;
  *'orgm-dot diff') exec kitty --class dot-diff -e sh -lc "hypr-orgm-dot diff; read -r -p 'press enter...'" ;;
  *'orgm-dot sync') exec kitty --class dot-sync -e sh -lc "hypr-orgm-dot sync; read -r -p 'press enter...'" ;;
  *'Open dotfiles') exec nautilus "$repo" ;;
  *'Power') exec hypr-power-menu ;;
  *) exit 0 ;;
esac
