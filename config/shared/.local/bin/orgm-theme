EOF
}

apply_gsettings() {
  command -v gsettings >/dev/null 2>&1 || return 0

  # In this distrobox/host bridge, gsettings may not see NixOS schemas unless
  # GSETTINGS_SCHEMA_DIR is explicit. Without this, GTK4/libadwaita apps like
  # Nautilus keep the old dark/light preference even though settings.ini changed.
  if [ -z "${GSETTINGS_SCHEMA_DIR:-}" ]; then
    schema_dir="$(find /run/current-system/sw /nix/store -path '*/gsettings-desktop-schemas-*/glib-2.0/schemas' -type d 2>/dev/null | head -n 1 || true)"
    [ -n "${schema_dir:-}" ] && export GSETTINGS_SCHEMA_DIR="$schema_dir"
  fi

  gsettings set org.gnome.desktop.interface color-scheme "$COLOR_SCHEME" 2>/dev/null || true
  gsettings set org.gnome.desktop.interface gtk-theme "$GTK_THEME" 2>/dev/null || true
  gsettings set org.gnome.desktop.interface icon-theme "$ICON_THEME" 2>/dev/null || true
  gsettings set org.gnome.desktop.interface cursor-theme "$CURSOR_THEME" 2>/dev/null || true
  gsettings set org.gnome.desktop.interface cursor-size "$CURSOR_SIZE" 2>/dev/null || true
}

write_pi_settings() {
  local settings="$HOME/.pi/agent/settings.json"
  local pi_theme="${PI_THEME:-$THEME_NAME}"
  [ -f "$settings" ] || return 0
  if command -v python3 >/dev/null 2>&1; then
    PI_THEME_NAME="$pi_theme" PI_SETTINGS_FILE="$settings" python3 - <<'PY'
import json
import os
from pathlib import Path

settings = Path(os.environ["PI_SETTINGS_FILE"])
theme = os.environ["PI_THEME_NAME"]
data = json.loads(settings.read_text())
data["theme"] = theme
settings.write_text(json.dumps(data, indent=2, ensure_ascii=False) + "\n")
PY
  else
    printf 'orgm-theme: python3 not found; skipping Pi settings theme update\n' >&2
  fi
}

reload_live() {
  command -v hyprctl >/dev/null 2>&1 && hyprctl reload >/dev/null 2>&1 || true

  # Dock owns right-side reserved space. Restart it before restarting apps or
  # Waybar so other surfaces do not claim its space during theme changes.
  if [ -x "$HOME/.local/bin/hypr-nwg-dock" ]; then
    "$HOME/.local/bin/hypr-nwg-dock" reload >/dev/null 2>&1 &
    sleep 0.5
  elif command -v hypr-nwg-dock >/dev/null 2>&1; then
    hypr-nwg-dock reload >/dev/null 2>&1 &
    sleep 0.5
  fi

  pkill -SIGUSR1 kitty 2>/dev/null || true
  command -v swaync-client >/dev/null 2>&1 && swaync-client -rs >/dev/null 2>&1 || true
  # GTK4/libadwaita apps and portal file pickers can cache appearance. Restart
  # lightweight user services/apps so Nautilus/filepicker follow dark/light now.
  command -v nautilus >/dev/null 2>&1 && nautilus -q >/dev/null 2>&1 || pkill -f '(^|/)nautilus( |$)' 2>/dev/null || true
  command -v systemctl >/dev/null 2>&1 && systemctl --user try-restart xdg-desktop-portal.service xdg-desktop-portal-gtk.service xdg-desktop-portal-hyprland.service >/dev/null 2>&1 || true

  if command -v waybar-watch >/dev/null 2>&1; then
    if ! pgrep -f "^[^ ]+sh .*waybar-watch $config_home/waybar-hypr$" >/dev/null 2>&1; then
      (waybar-watch "$config_home/waybar-hypr" >/dev/null 2>&1 &)
    fi
  fi
}

apply_theme() {
  local theme="$1"
  local previous_theme
  previous_theme="$(cat "$current_file" 2>/dev/null || true)"
  save_current_wallpaper_for_theme "$previous_theme"
  need_theme "$theme"
  write_current_env
  write_kitty
  write_rofi
  write_fuzzel
  write_waybar_palette
  write_dock
  write_swaync
  write_quickshell
  write_gtk_qt
  write_hypr_scheme
  apply_gsettings
  write_pi_settings
  reload_live
  restore_wallpaper_for_theme "$THEME_NAME"
  echo "Applied $THEME_NAME"
}

cmd="${1:-}"
case "$cmd" in
  list) find "$themes_dir" -maxdepth 1 -name '*.env' -printf '%f\n' | sed 's/\.env$//' | sort ;;
  current) cat "$current_file" 2>/dev/null || echo orgm-dark ;;
  apply) [ -n "${2:-}" ] || { usage; exit 2; }; apply_theme "$2" ;;
  toggle)
    current="$(cat "$current_file" 2>/dev/null || echo orgm-dark)"
    [ "$current" = orgm-light ] && apply_theme orgm-dark || apply_theme orgm-light
    ;;
  status)
    theme="$(cat "$current_file" 2>/dev/null || echo orgm-dark)"
    need_theme "$theme"
    printf 'Theme: %s\nGTK: %s\nIcons: %s\nCursor: %s %s\nColor scheme: %s\nPi theme: %s\n' "$THEME_NAME" "$GTK_THEME" "$ICON_THEME" "$CURSOR_THEME" "$CURSOR_SIZE" "$COLOR_SCHEME" "${PI_THEME:-$THEME_NAME}"
    ;;
  -h|--help|help|'') usage ;;
  *) echo "orgm-theme: unknown command: $cmd" >&2; usage; exit 2 ;;
esac
