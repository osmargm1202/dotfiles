  cat >"$config_home/gtk-3.0/settings.ini" <<EOF
[Settings]
gtk-theme-name=$GTK_THEME
gtk-application-prefer-dark-theme=$([ "$COLOR_SCHEME" = prefer-dark ] && echo true || echo false)
gtk-icon-theme-name=$ICON_THEME
gtk-cursor-theme-name=$CURSOR_THEME
gtk-cursor-theme-size=$CURSOR_SIZE
gtk-font-name=JetBrains Mono 11
gtk-xft-antialias=1
gtk-xft-hinting=1
gtk-xft-hintstyle=hintslight
gtk-xft-rgba=none
gtk-overlay-scrolling=true
EOF
  cp "$config_home/gtk-3.0/settings.ini" "$config_home/gtk-4.0/settings.ini"
  rm -f "$config_home/gtk-4.0/gtk.css" "$config_home/gtk-4.0/gtk-dark.css"
  cat >"$config_home/gtk-4.0/gtk.css" <<EOF
