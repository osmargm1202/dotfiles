  mkdir -p "$config_home/rofi"
  cat >"$config_home/rofi/orgm-current.rasi" <<EOF
/* Generated by orgm-theme. */
* {
    bg-col: #${MENU_BG};
    surface-col: #${QS_CARD};
    border-col: #${BLUE};
    selected-col: #${QS_CARD_STRONG};
    fg-col: #${TEXT};
    fg-col2: #${BLUE};
    prompt-fg: #${ON_ACCENT};
}
EOF
}

write_fuzzel() {
  mkdir -p "$config_home/fuzzel"
  cat >"$config_home/fuzzel/fuzzel.ini" <<EOF
font=JetBrainsMono Nerd Font:size=12
icon-theme=$ICON_THEME
terminal=kitty
prompt="Apps> "
layer=overlay
width=34
lines=10
horizontal-pad=12
vertical-pad=10
inner-pad=6
line-height=22
fields=name,generic,comment,categories,filename,keywords
show-actions=yes

[colors]
background=${MENU_BG}
text=${TEXT}ff
match=${BLUE}ff
selection=${QS_CARD_STRONG}
selection-text=${TEXT}ff
selection-match=${PINK}ff
border=${BLUE}ff

[border]
width=2
radius=10
EOF
}

write_waybar_palette() {
  local dir panel_bg_css panel_border_css
  panel_bg_css="$(css_color "$PANEL_BG")"
  panel_border_css="$(css_color "${BLUE}ff")"
  for dir in "$config_home/waybar" "$config_home/waybar-hypr"; do
    mkdir -p "$dir"
    cat >"$dir/orgm-current.css" <<EOF
/* Generated by orgm-theme. */
@define-color base   #$BASE;
@define-color mantle #$MANTLE;
@define-color crust  #$CRUST;
@define-color text     #$TEXT;
@define-color subtext0 #$SUBTEXT0;
@define-color subtext1 #$SUBTEXT1;
@define-color surface0 #$SURFACE0;
@define-color surface1 #$SURFACE1;
@define-color surface2 #$SURFACE2;
@define-color overlay0 #$OVERLAY0;
@define-color overlay1 #$OVERLAY1;
@define-color overlay2 #$OVERLAY2;
@define-color blue      #$BLUE;
@define-color lavender  #$MAUVE;
@define-color sapphire  #$SKY;
@define-color sky       #$SKY;
@define-color teal      #$TEAL;
@define-color green     #$GREEN;
@define-color yellow    #$YELLOW;
@define-color peach     #$PEACH;
@define-color maroon    #$PEACH;
@define-color red       #$RED;
@define-color mauve     #$MAUVE;
@define-color pink      #$PINK;
@define-color flamingo  #$ROSEWATER;
@define-color rosewater #$ROSEWATER;
@define-color panel_bg $panel_bg_css;
@define-color panel_border $panel_border_css;
EOF
  done
}

write_dock() {
  mkdir -p "$config_home/nwg-dock-hyprland"
  cat >"$config_home/nwg-dock-hyprland/orgm-current.css" <<EOF
/* Generated by orgm-theme. Keep dock as icons only in dark and light modes. */
window {
  background: transparent;
  border: none;
  box-shadow: none;
}
#box {
  background: transparent;
  border: none;
  box-shadow: none;
}
button,
button:hover,
button:focus,
button:checked,
button.active {
  background: transparent;
  border: none;
  box-shadow: none;
}
EOF
}

