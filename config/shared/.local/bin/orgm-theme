#!/usr/bin/env bash
set -euo pipefail

config_home="${XDG_CONFIG_HOME:-$HOME/.config}"
state_home="${XDG_STATE_HOME:-$HOME/.local/state}"
data_home="${XDG_DATA_HOME:-$HOME/.local/share}"
theme_home="$config_home/orgm-theme"
themes_dir="$theme_home/themes"
state_dir="$state_home/orgm-theme"
current_file="$state_dir/current"

usage() {
  cat <<'EOF'
Usage: orgm-theme <command> [theme]

Commands:
  list              List available themes
  current           Print current theme
  apply THEME       Apply theme (orgm-dark or orgm-light)
  toggle            Toggle orgm-dark/orgm-light
  status            Show current theme and key toolkit settings
EOF
}

need_theme() {
  local theme="$1"
  local file="$themes_dir/$theme.env"
  [ -r "$file" ] || { echo "orgm-theme: theme not found: $theme" >&2; exit 1; }
  # shellcheck disable=SC1090
  . "$file"
}

hex_to_rgb() {
  local h="${1#\#}"
  printf '%d, %d, %d' "0x${h:0:2}" "0x${h:2:2}" "0x${h:4:2}"
}

css_color() {
  local h="${1#\#}"
  case "${#h}" in
    6) printf '#%s' "$h" ;;
    8)
      local red green blue alpha alpha_dec alpha_trimmed
      red=$((16#${h:0:2}))
      green=$((16#${h:2:2}))
      blue=$((16#${h:4:2}))
      alpha=$((16#${h:6:2}))
      alpha_dec=$(awk -v a="$alpha" 'BEGIN { printf "%.3f", a / 255 }')
      alpha_trimmed=$(printf '%s' "$alpha_dec" | sed -e 's/0*$//' -e 's/\.$//')
      printf 'rgba(%d, %d, %d, %s)' "$red" "$green" "$blue" "$alpha_trimmed"
      ;;
    *) printf '#%s' "$h" ;;
  esac
}

state_value_from_file() {
  local file="$1"
  local key="$2"
  local line
  [ -r "$file" ] || return 0
  while IFS= read -r line; do
    case "$line" in
      "$key"=*) printf '%s\n' "${line#*=}"; return 0 ;;
    esac
  done <"$file"
}

save_current_wallpaper_for_theme() {
  local theme="$1"
  local wallpaper_state="$state_home/hypr-wallpaper/state"
  local monitor_state_dir="$state_home/hypr-wallpaper/monitors"
  local mode path out tmp monitor_out
  [ -n "$theme" ] || return 0
  mode="$(state_value_from_file "$wallpaper_state" mode)"
  path="$(state_value_from_file "$wallpaper_state" path)"
  [ -n "$path" ] || return 0
  mkdir -p "$state_dir/wallpapers"
  out="$state_dir/wallpapers/$theme.state"
  tmp="$out.$$"
  printf 'mode=%s\npath=%s\n' "${mode:-static}" "$path" >"$tmp"
  mv "$tmp" "$out"

  monitor_out="$state_dir/wallpapers/$theme.monitors"
  rm -rf "$monitor_out"
  if [ -d "$monitor_state_dir" ] && find "$monitor_state_dir" -maxdepth 1 -type f -name '*.state' | grep -q .; then
    mkdir -p "$monitor_out"
    cp "$monitor_state_dir"/*.state "$monitor_out"/ 2>/dev/null || true
  fi
}

restore_wallpaper_for_theme() {
  local theme="$1"
  local saved="$state_dir/wallpapers/$theme.state"
  local monitor_saved_dir="$state_dir/wallpapers/$theme.monitors"
  local mode path file output restored
  [ -n "$theme" ] || return 0
  [ -r "$saved" ] || return 0
  command -v orgm-wallpaper >/dev/null 2>&1 || return 0
  mode="$(state_value_from_file "$saved" mode)"
  path="$(state_value_from_file "$saved" path)"
  [ -n "$path" ] || return 0
  case "$mode" in
    video*) orgm-wallpaper set-video "$path" >/dev/null 2>&1 || true; return 0 ;;
  esac

  restored=0
  if [ -d "$monitor_saved_dir" ]; then
    for file in "$monitor_saved_dir"/*.state; do
      [ -r "$file" ] || continue
      output="$(basename "$file" .state)"
      path="$(state_value_from_file "$file" path)"
      [ -n "$output" ] && [ -n "$path" ] || continue
      orgm-wallpaper set-static "$path" --monitor "$output" >/dev/null 2>&1 || true
      restored=1
    done
  fi
  [ "$restored" -eq 1 ] && return 0
  orgm-wallpaper set-static "$path" >/dev/null 2>&1 || true
}

write_current_env() {
  mkdir -p "$state_dir" "$theme_home"
  cp "$themes_dir/$THEME_NAME.env" "$state_dir/current.env"
  printf '%s\n' "$THEME_NAME" >"$current_file"
}

write_kitty() {
  mkdir -p "$config_home/kitty"
  cat >"$config_home/kitty/current-theme.conf" <<EOF
# Generated by orgm-theme. Do not edit.
foreground #$TEXT
background #$BASE
background_opacity ${KITTY_BACKGROUND_OPACITY:-0.90}
selection_foreground #$ON_ACCENT
selection_background #$BLUE
cursor #$TEXT
cursor_text_color #$BASE
url_color #$SKY
active_border_color #$BLUE
inactive_border_color #$SURFACE0
bell_border_color #$YELLOW
active_tab_foreground #$ON_ACCENT
active_tab_background #$BLUE
inactive_tab_foreground #$TEXT
inactive_tab_background #$SURFACE0
color0 #$CRUST
color1 #$RED
color2 #$GREEN
color3 #$YELLOW
color4 #$BLUE
color5 #$MAUVE
color6 #$TEAL
color7 #$TEXT
color8 #$OVERLAY0
color9 #$RED
color10 #$GREEN
color11 #$YELLOW
color12 #$BLUE
color13 #$PINK
color14 #$SKY
color15 #$ROSEWATER
EOF
}

