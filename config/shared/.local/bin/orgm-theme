\$error = $RED
\$term0 = $CRUST
\$term1 = $RED
\$term2 = $GREEN
\$term3 = $YELLOW
\$term4 = $BLUE
\$term5 = $MAUVE
\$term6 = $TEAL
\$term7 = $TEXT
