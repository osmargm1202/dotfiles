#!/usr/bin/env bash
set -euo pipefail

log_dir="${XDG_STATE_HOME:-$HOME/.local/state}/hyprchy"
mkdir -p "$log_dir"

start_if_missing() {
  local name="$1"
  shift

  command -v "$name" >/dev/null 2>&1 || return 0
  if pgrep -xu "${USER:-$(id -un)}" -x "$name" >/dev/null 2>&1; then
    return 0
  fi

  nohup "$@" >>"$log_dir/$name.log" 2>&1 &
}

# Elephant is Walker's provider backend. Walker's NixOS module intentionally does
# not install a working system service, so Hyprland starts both in user session.
start_if_missing elephant elephant
start_if_missing walker walker --gapplication-service
