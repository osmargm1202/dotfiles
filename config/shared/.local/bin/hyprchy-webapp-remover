#!/usr/bin/env bash
set -euo pipefail

theme="${HYPRCHY_ROFI_THEME:-$HOME/.config/rofi-hyprchy/control-center.rasi}"
apps_dir="${XDG_DATA_HOME:-$HOME/.local/share}/applications"
state_dir="${XDG_DATA_HOME:-$HOME/.local/share}/hyprchy/webapps"

tmp="$(mktemp)"
trap 'rm -f "$tmp"' EXIT

if [ -d "$apps_dir" ]; then
  find "$apps_dir" -maxdepth 1 -type f -name 'hyprchy-webapp-*.desktop' -print 2>/dev/null | sort | while read -r file; do
    grep -q '^X-Hyprchy-WebApp=true$' "$file" || continue
    name="$(sed -n 's/^Name=//p' "$file" | head -n1)"
    url="$(sed -n 's/^X-Hyprchy-WebApp-URL=//p' "$file" | head -n1)"
    printf '%s\t%s\t%s\n' "${name:-$(basename "$file")}" "$url" "$file"
  done > "$tmp"
fi

if [ ! -s "$tmp" ]; then
  notify-send 'Hyprchy App Remover' 'No Hyprchy web apps found.' 2>/dev/null || true
  exit 0
fi

selection="$(awk -F '\t' '{ printf "%s — %s\n", $1, $2 }' "$tmp" | rofi -dmenu -i -p 'Remove web app' -theme "$theme" || true)"
[ -n "$selection" ] || exit 0

name="${selection%% — *}"
file="$(awk -F '\t' -v n="$name" '$1 == n { print $3; exit }' "$tmp")"
[ -n "$file" ] && [ -f "$file" ] || exit 1

launcher="$(sed -n 's/^Exec=//p' "$file" | head -n1)"
slug="$(basename "$file" .desktop | sed 's/^hyprchy-webapp-//')"
profile="$state_dir/profiles/$slug"
safe_launcher="$state_dir/bin/hyprchy-webapp-$slug"
confirm="$(printf '%s\n' 'Remove launcher only' 'Remove launcher and profile data' 'Cancel' | rofi -dmenu -i -p "Remove $name?" -theme "$theme" || true)"

case "$confirm" in
  'Remove launcher only')
    rm -f "$file"
    if [ "$launcher" = "$safe_launcher" ]; then
      rm -f "$safe_launcher"
    fi
    ;;
  'Remove launcher and profile data')
    rm -f "$file"
    if [ "$launcher" = "$safe_launcher" ]; then
      rm -f "$safe_launcher"
    fi
    [ -n "$slug" ] && rm -rf "$profile"
    ;;
  *) exit 0 ;;
esac

update-desktop-database "$apps_dir" >/dev/null 2>&1 || true
notify-send 'Hyprchy App Remover' "Removed $name" 2>/dev/null || true
