#!/usr/bin/env bash
set -euo pipefail

theme="${HYPRCHY_ROFI_THEME:-$HOME/.config/rofi-hyprchy/control-center.rasi}"
choice="$(printf '%s\n' '󰌌 Keybindings' '󰉋 Open Hypr config' '󰉋 Open dotfiles repo' '󰅖 Cancel' | rofi -dmenu -i -p 'Help' -theme "$theme" || true)"

case "$choice" in
  *'Keybindings') exec ~/.local/bin/hypr-keybindings-help ;;
  *'Hypr config') exec nautilus "$HOME/.config/hypr" ;;
  *'dotfiles') exec nautilus "$HOME/Hobby/dotfiles" ;;
  *) exit 0 ;;
esac
