#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "usage: sway-app-dock status|click <app>" >&2
  exit 2
}

mode="${1:-}"
app="${2:-}"
[ -n "$mode" ] && [ -n "$app" ] || usage

case "$app" in
  windows)
    match='true'
    command='swaymsg -t get_tree | jq -r '\''.. | objects | select(.type? == "con" and (.app_id? or .window_properties?.class?)) | "\(.id)\t\(.name // "untitled")"'\'' | fuzzel --dmenu --prompt "Windows> " | cut -f1 | xargs -r swaymsg "[con_id=__ID__] focus"'
    ;;
  kitty)
    match='(.app_id? == "kitty" or .window_properties?.class? == "kitty")'
    command='kitty'
    ;;
  nautilus)
    match='(.app_id? == "org.gnome.Nautilus" or .window_properties?.class? == "org.gnome.Nautilus")'
    command='nautilus'
    ;;
  zen)
    match='(.app_id? == "app.zen_browser.zen" or .app_id? == "zen-browser" or .window_properties?.class? == "zen-browser" or .window_properties?.class? == "Zen")'
    command='flatpak run app.zen_browser.zen'
    ;;
  chromium)
    match='(.app_id? == "chromium" or .app_id? == "chromium-browser" or .window_properties?.class? == "Chromium")'
    command='chromium'
    ;;
  obsidian)
    match='(.app_id? == "obsidian" or .app_id? == "md.obsidian.Obsidian" or .window_properties?.class? == "obsidian")'
    command='obsidian'
    ;;
  software)
    match='(.app_id? == "org.gnome.Software" or .window_properties?.class? == "org.gnome.Software")'
    command='gnome-software'
    ;;
  *) usage ;;
esac

sway_tree() {
  swaymsg -t get_tree 2>/dev/null || printf '{}'
}

first_match_id() {
  sway_tree | jq -r "[recurse(.nodes[]?, .floating_nodes[]?) | select($match) | .id][0] // empty"
}

active_match_id() {
  sway_tree | jq -r "[recurse(.nodes[]?, .floating_nodes[]?) | select(.focused? == true and ($match)) | .id][0] // empty"
}

case "$mode" in
  status)
    if [ "$app" = "windows" ]; then
      text="WIN"
      tooltip="Ventanas"
      class="dock"
    else
      text="●"
      tooltip="$app"
      class="dock"
    fi
    if [ -n "$(first_match_id)" ]; then
      class="running"
    fi
    if [ -n "$(active_match_id)" ]; then
      class="active"
    fi
    jq -cn --arg text "$text" --arg tooltip "$tooltip" --arg class "$class" \
      '{text:$text, tooltip:$tooltip, class:$class}'
    ;;
  click)
    if [ "$app" = "windows" ]; then
      selection="$(sway_tree | jq -r '.. | objects | select(.type? == "con" and (.app_id? or .window_properties?.class?)) | "\(.id)\t\(.name // "untitled")"' | fuzzel --dmenu --prompt 'Windows> ' || true)"
      [ -n "$selection" ] || exit 0
      con_id="${selection%%$'\t'*}"
      exec swaymsg "[con_id=$con_id] focus"
    fi
    con_id="$(first_match_id)"
    if [ -n "$con_id" ]; then
      exec swaymsg "[con_id=$con_id] focus"
    fi
    exec sh -lc "$command"
    ;;
  *) usage ;;
esac
