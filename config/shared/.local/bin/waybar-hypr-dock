#!/bin/sh
set -eu

config="${WAYBAR_HYPR_DOCK_CONFIG:-$HOME/.config/waybar-hypr/dock-apps.json}"
state_dir="${XDG_RUNTIME_DIR:-/tmp}/waybar-hypr-dock"

usage() {
  echo "usage: waybar-hypr-dock status|click|launch APP_ID" >&2
  exit 2
}

[ "$#" -eq 2 ] || usage
action="$1"
app_id="$2"

app_json="$(jq -c --arg id "$app_id" '.[] | select(.id == $id)' "$config")"
[ -n "$app_json" ] || { echo "unknown dock app: $app_id" >&2; exit 1; }

app_name="$(printf '%s' "$app_json" | jq -r '.name // .id')"
launch_cmd="$(printf '%s' "$app_json" | jq -r '.launch // empty')"

clients_json() {
  hyprctl clients -j 2>/dev/null || printf '[]'
}

active_address() {
  hyprctl activewindow -j 2>/dev/null | jq -r '.address // empty' 2>/dev/null || true
}

matched_clients() {
  clients_json | jq -c --argjson app "$app_json" '
    [ .[]
      | (.class // "" | ascii_downcase) as $class
      | (.initialClass // "" | ascii_downcase) as $initial
      | (.title // "" | ascii_downcase) as $title
      | (($app.match.class // []) | map(ascii_downcase)) as $classes
      | (($app.match.title // []) | map(ascii_downcase)) as $titles
      | select(
          (($classes | index($class)) != null)
          or (($classes | index($initial)) != null)
          or (any($titles[]?; . as $needle | $needle != "" and ($title | contains($needle))))
        )
    ] | sort_by(.workspace.name // "", .address // "")'
}

launch_app() {
  [ -n "$launch_cmd" ] || exit 0
  sh -lc "$launch_cmd" >/dev/null 2>&1 &
}

focus_address() {
  addr="$1"
  [ -n "$addr" ] || exit 0
  hyprctl dispatch focuswindow "address:$addr" >/dev/null 2>&1 || true
}

case "$action" in
  status)
    clients="$(matched_clients)"
    count="$(printf '%s' "$clients" | jq 'length')"
    active="$(active_address)"
    is_active="$(printf '%s' "$clients" | jq --arg active "$active" 'any(.[]; .address == $active)')"
    dots=""
    max="$count"
    [ "$max" -gt 5 ] && max=5
    i=0
    while [ "$i" -lt "$max" ]; do dots="${dots}●"; i=$((i + 1)); done
    [ -n "$dots" ] || dots=" "
    classes='["dock-app"]'
    [ "$count" -gt 0 ] && classes='["dock-app","running"]'
    [ "$is_active" = "true" ] && classes='["dock-app","running","active"]'
    jq -cn --arg text "$dots" --arg tooltip "$app_name: $count ventana(s)" --argjson class "$classes" \
      '{text:$text, tooltip:$tooltip, class:$class}'
    ;;
  click)
    clients="$(matched_clients)"
    count="$(printf '%s' "$clients" | jq 'length')"
    if [ "$count" -eq 0 ]; then
      launch_app
      exit 0
    fi
    if [ "$count" -eq 1 ]; then
      addr="$(printf '%s' "$clients" | jq -r '.[0].address // empty')"
      focus_address "$addr"
      exit 0
    fi

    selection="$(printf '%s' "$clients" | jq -r '.[] | "\(.address)\t[\(.workspace.name // "?")] \(.title // .class // "window")"' | hypr-dmenu --prompt "${app_name}> " 2>/dev/null || true)"
    addr="$(printf '%s' "$selection" | cut -f1)"
    focus_address "$addr"
    ;;
  launch)
    launch_app
    ;;
  *) usage ;;
esac
