	{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",


  "display": {
    "separator": " ➜ ",
    "key": {
      "width": 18
    }
  },

  "modules": [
    {
      "type": "title",
      "host": "false"
    },
    "separator",

    {
      "type": "custom",
      "format": "\u001b[1;35m╭────────────────────────────────── SYSTEM ──────────────────────────────────╮\u001b[0m"
    },

    {
      "type": "cpu",
      "key": " CPU",
      "keyColor": "magenta"
    },
    {
      "type": "gpu",
      "key": "󰢮 GPU",
      "keyColor": "magenta"
    },
    {
      "type": "memory",
      "key": "󰍛 Memory",
      "keyColor": "magenta"
    },

    {
      "type": "custom",
      "format": "\u001b[1;35m╰────────────────────────────────────────────────────────────────────────────╯\u001b[0m"
    },

    {
      "type": "custom",
      "format": "\u001b[1;34m╭───────────────────────────────── STORAGE ──────────────────────────────────╮\u001b[0m"
    },

    {
      "type": "disk",
      "key": "󰋊 Disk",
      "keyColor": "blue"
    },
    {
      "type": "swap",
      "key": "󰾴 Swap",
      "keyColor": "blue"
    },

    {
      "type": "custom",
      "format": "\u001b[1;34m╰────────────────────────────────────────────────────────────────────────────╯\u001b[0m"
    },

    {
      "type": "custom",
      "format": "\u001b[1;36m╭───────────────────────────────── SESSION ──────────────────────────────────╮\u001b[0m"
    },

    {
      "type": "uptime",
      "key": "󰅐 Uptime",
      "keyColor": "cyan"
    },
    {
      "type": "packages",
      "key": "󰏖 Packages",
      "keyColor": "cyan"
    },
    {
      "type": "shell",
      "key": " Shell",
      "keyColor": "cyan"
    },
    {
      "type": "terminal",
      "key": " Terminal",
      "keyColor": "cyan"
    },

    {
      "type": "custom",
      "format": "\u001b[1;36m╰────────────────────────────────────────────────────────────────────────────╯\u001b[0m"
    },

    "break",

    {
      "type": "colors",
      "symbol": "circle",
      "paddingLeft": 3
    }
  ]
}
