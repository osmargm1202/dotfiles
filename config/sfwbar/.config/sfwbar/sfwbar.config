#Api2

Theme = "Adwaita-dark"
IconTheme = "Papirus-Dark"

Set ImagePath = "icons/misc"
Set ThicknessHint = "42px"
Set Term = "kitty"

# Display minimized windows on taskbars across all outputs.
DisownMinimized = true

TriggerAction "SIGRTMIN+1", SwitcherEvent("forward");
TriggerAction "SIGRTMIN+2", SwitcherEvent("back");

Function SfwbarInit() {
# Config "PopUp 'XVolumeWindow' { AutoClose = true }"
}

placer {
  xorigin = 5
  yorigin = 5
  xstep = 5
  ystep = 5
  children = true
}

switcher {
  disable = false
  interval = 700
  icons = true
  labels = false
  cols = 5
}

include "winops.widget"

bar {
  edge = "bottom"
  layer = "top"
  mirror = "*"
  exclusive_zone = "auto"

  widget "startmenu.widget"
  widget "showdesktop.widget"

  taskbar {
    style = "taskbar"
    rows = 1
    tooltips = true
    icons = true
    labels = false
    group = true
    group.icons = true
    group.labels = false
    group.rows = 1
    sort = true
    action[RightClick] = Menu("winops")
    action[MiddleClick] = Close()
    action[Drag] = Focus()
  }

  label {
    css = "* { -GtkWidget-hexpand: true; }"
  }

  tray {
    rows = 1
    css = "grid { -GtkWidget-column-homogeneous: false; }"
  }

  widget "volume.widget" {
    simple_icon = true
    volume_thresholds = [80, 50, 0]
    volume_icons = ["audio-volume-high", "audio-volume-medium", "audio-volume-low"]
    volume_muted = "audio-volume-muted"
  }

  widget "network.widget"

  widget "battery.widget" {
    simple_icon = true
  }

  widget "clock.widget" {
    disable = false
    time_format = "%H:%M"
    tooltip_format = "%H:%M\n%x"
    week_starts_on_sunday = false
    reset_on_popup = false
  }

  widget "session.widget" {
    session_actions = [
      ["system-lock-screen", "Lock", "swaylock -f -c 000000"],
      ["system-suspend", "Suspend", "systemctl suspend"],
      ["system-log-out", "Logout", "loginctl terminate-user $USER"],
      ["system-reboot", "Reboot", "systemctl reboot"],
      ["system-shutdown", "Shutdown", "systemctl poweroff"]
    ]
  }
}

#CSS
@define-color theme_bg_color rgba(18,18,22,0.82);
@define-color theme_panel_color rgba(255,255,255,0.08);
@define-color theme_panel_hover rgba(255,255,255,0.14);
@define-color theme_accent_color #78aaff;
@define-color theme_text_color #f2f2f2;
@define-color theme_dim_color rgba(242,242,242,0.55);
@define-color borders rgba(255,255,255,0.12);

#hidden {
  -GtkWidget-visible: false;
}

* {
  -GtkWidget-vexpand: true;
  box-shadow: none;
  border-image: none;
  background-image: none;
  outline-style: none;
  color: @theme_text_color;
}

window#sfwbar {
  background-color: @theme_bg_color;
  border-top: 1px solid @borders;
}

tooltip,
menu {
  background-color: rgba(18,18,22,0.96);
  border: 1px solid @borders;
  border-radius: 10px;
  padding: 6px;
  color: @theme_text_color;
}

menuitem {
  color: @theme_text_color;
  padding: 5px 8px;
  border-radius: 8px;
}

menuitem:hover {
  background-color: @theme_panel_hover;
}

label {
  font-family: "Adwaita Sans", "JetBrainsMono Nerd Font", sans-serif;
  font-size: calc(@bar_thickness * 0.36);
  color: @theme_text_color;
  text-shadow: none;
}

image {
  min-width: 16px;
  min-height: 16px;
  background: none;
  color: @theme_text_color;
  -gtk-icon-shadow: none;
}

button {
  background: none;
  border: none;
  border-radius: 14px;
  margin: 3px;
}

button:hover {
  background-color: @theme_panel_hover;
}

.module,
button#startmenu,
button#showdesktop,
button#module {
  background-color: @theme_panel_color;
  border: 1px solid transparent;
  border-radius: 14px;
  padding: 5px 9px;
  margin: 4px 3px;
  -GtkWidget-valign: center;
}

.module image,
button#startmenu image,
button#showdesktop image,
button#module image {
  min-width: 22px;
  min-height: 22px;
  padding: 0px;
  margin: 0px;
  -GtkWidget-valign: center;
  -GtkWidget-vexpand: true;
  -ScaleImage-symbolic: true;
}

/* Taskbar: app icons large, labels hidden, grouped by app_id. */
button#taskbar_item {
  min-width: 48px;
  min-height: 34px;
  padding: 3px 8px;
  margin: 4px 3px;
  border-radius: 14px;
  background-color: @theme_panel_color;
  border: 1px solid transparent;
  -GtkWidget-hexpand: false;
}

button#taskbar_item:hover {
  background-color: @theme_panel_hover;
  border-color: @borders;
}

button#taskbar_item.focused {
  background-color: rgba(120,170,255,0.24);
  border-color: alpha(@theme_accent_color,0.65);
}

button#taskbar_item.minimized {
  opacity: 0.58;
}

button#taskbar_item.urgent {
  background-color: rgba(255,90,90,0.28);
  border-color: rgba(255,90,90,0.7);
}

button#taskbar_item grid {
  -GtkWidget-valign: center;
}

button#taskbar_item image {
  min-width: 32px;
  min-height: 32px;
  padding: 0px;
  margin: 0px;
  -ScaleImage-symbolic: false;
}

button#taskbar_item label {
  -GtkWidget-visible: false;
}

/* System tray: keep icons smaller than app taskbar icons. */
button#tray_item {
  min-width: 24px;
  min-height: 24px;
  margin: 4px 1px;
  padding: 2px;
  border: none;
  border-radius: 8px;
  background: transparent;
  -GtkWidget-valign: center;
}

button#tray_item:hover {
  background-color: @theme_panel_hover;
}

button#tray_item.passive {
  -GtkWidget-visible: false;
}

button#tray_item image {
  min-width: 18px;
  min-height: 18px;
  padding: 0px;
  margin: 0px;
  border: none;
  -GtkWidget-valign: center;
  -GtkWidget-vexpand: true;
  -ScaleImage-symbolic: false;
}

/* Switcher */
window#switcher {
  background-color: rgba(0,0,0,0);
  padding: 8px;
  -GtkWidget-hexpand: true;
}

grid#switcher {
  border-radius: 16px;
  background-color: rgba(18,18,22,0.94);
  border: 1px solid @borders;
  padding: 10px;
  -GtkWidget-hexpand: true;
}

grid#switcher_item.focused image,
grid#switcher_item.focused {
  background-color: rgba(120,170,255,0.28);
  border-radius: 12px;
}

grid#switcher_item image,
grid#switcher_item {
  min-width: 58px;
  min-height: 58px;
  padding: 6px;
  border-radius: 12px;
  -GtkWidget-hexpand: true;
  -ScaleImage-symbolic: false;
}
