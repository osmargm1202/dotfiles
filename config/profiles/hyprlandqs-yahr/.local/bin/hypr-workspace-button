#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "usage: hypr-workspace-button status|click WORKSPACE_ID" >&2
  exit 2
}

[ "$#" -eq 2 ] || usage
action="$1"
workspace="$2"

case "$workspace" in
  ''|*[!0-9]*) usage ;;
esac

focus_workspace() {
  hyprctl dispatch "hl.dsp.focus({ workspace = $workspace })" >/dev/null
}

status_workspace() {
  active="$(hyprctl -j monitors 2>/dev/null | jq -r 'map(select(.focused == true))[0].activeWorkspace.id // .[0].activeWorkspace.id // empty')"
  windows="$(hyprctl -j workspaces 2>/dev/null | jq --argjson id "$workspace" 'map(select(.id == $id))[0].windows // 0')"
  class='["workspace","empty"]'
  if [ "${windows:-0}" -gt 0 ]; then
    class='["workspace","occupied"]'
  fi
  if [ "$active" = "$workspace" ]; then
    class='["workspace","active"]'
  fi
  jq -cn --arg text "$workspace" --arg tooltip "Workspace $workspace · ${windows:-0} window(s)" --argjson class "$class" \
    '{text:$text, tooltip:$tooltip, class:$class}'
}

case "$action" in
  click) focus_workspace ;;
  status) status_workspace ;;
  *) usage ;;
esac
