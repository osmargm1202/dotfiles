# Mako Notification Daemon Configuration
# Theme: Catppuccin Macchiato

# General settings
font=JetBrainsMono 13
markup=1
max-visible=5
sort=-time
layer=overlay
anchor=top-right
margin=8
padding=14
border-size=1
border-radius=16
background-color=#24273aE8
text-color=#cad3f5
border-color=#8aadf459
progress-color=over #8aadf459

# Default timeout
default-timeout=10000

# Dimensions
width=400
height=150
max-icon-size=48

# Grouping
group-by=app-name

# Urgency levels
[urgency=low]
border-color=#a6da9559
default-timeout=5000

[urgency=normal]
border-color=#8aadf459
default-timeout=10000

[urgency=critical]
border-color=#ed8796
default-timeout=0

# Icons
icons=1
icon-path=/run/current-system/sw/share/icons/Papirus-Dark

# Format
format=<b>%s</b>\n%b
