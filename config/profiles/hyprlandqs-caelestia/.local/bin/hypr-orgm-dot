#!/usr/bin/env bash
set -euo pipefail

repo="${DOTFILES_REPO:-$HOME/Hobby/dotfiles}"
action="${1:-status}"
shift || true

run_orgm_dot() {
  cd "$repo"
  if command -v orgm-dot >/dev/null 2>&1; then
    exec orgm-dot "$action" "$@"
  fi
  if [ -x "$HOME/go/bin/orgm-dot" ]; then
    exec "$HOME/go/bin/orgm-dot" "$action" "$@"
  fi
  if [ -f "$repo/cmd/orgm-dot/main.go" ] && command -v go >/dev/null 2>&1; then
    exec go run ./cmd/orgm-dot "$action" "$@"
  fi
  printf 'No encontré orgm-dot ni go para ejecutar orgm-dot %s\n' "$action" >&2
  exit 127
}

case "$action" in
  status|diff|sync) run_orgm_dot "$@" ;;
  *)
    printf 'Usage: hypr-orgm-dot [status|diff|sync] [args...]\n' >&2
    exit 2
    ;;
esac
