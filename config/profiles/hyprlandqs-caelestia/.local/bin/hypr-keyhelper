#!/bin/sh
set -eu

lib="${HYPR_ROFI_LIB:-$HOME/.local/bin/hypr-rofi-lib}"
# shellcheck disable=SC1090
. "$lib"

ENTRIES="$(cat <<'EOF'
 Win+/           → Atajos Hyprland (este menú)
 Win+Enter       → Terminal (kitty)
 Win+Space       → Launcher Caelestia
 Win+Alt+Space   → Menú QS
 Win+E           → Explorador de archivos
 Win+O           → Obsidian
 Win+W           → Nueva ventana Zen
───────────────────────────────
 Win+M           → Buscar archivo
 Win+Ctrl+M      → Buscar archivo (dir)
 Win+Shift+M     → Buscar archivo (terminal)
 Win+Esc         → Cambiar ventana
 Win+Shift+T     → Sesiones tmux arch
 Win+C           → Calculadora
 Win+D           → SSH host
 Win+V           → Portapapeles
───────────────────────────────
 Win+Alt+L       → Bloquear pantalla
 Win+Alt+E       → Power menu
 Win+F10         → Audio (pavucontrol)
 Ctrl+Space      → Cambiar distribución teclado
 Win+S           → Scratchpad toggle
 Print           → Captura de pantalla (área)
 Win+Print       → Grabar pantalla (MP4)
 Win+Shift+Print → Grabar pantalla (GIF)
EOF
)"

printf '%s\n' "$ENTRIES" | rofi \
  -dmenu \
  -p "Atajos" \
  -i \
  -no-fixed-num-lines \
  -no-custom \
  -theme-str 'window { width: 680px; } listview { lines: 24; }' \
  || true
