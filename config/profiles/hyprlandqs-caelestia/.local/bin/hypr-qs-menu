#!/usr/bin/env bash
# Quick menu for hyprlandqs profile — uses rofi dmenu.

# shellcheck source=hypr-rofi-lib
. "$(dirname "$0")/hypr-rofi-lib"
hypr_rofi_load_env

MENU_ENTRIES=(
  "  Lock Screen"
  "  Power Menu"
  "  Wifi"
  "  Bluetooth"
  "  Audio Devices"
  "  Keyboard Layout"
  "  USB Devices"
  "  Performance"
  "  Kill Window"
  "  Clipboard"
  "  SSH Hosts"
  "  Open File"
  "  Calc"
  "  Obsidian"
  "  Webapp Maker"
)

CHOICE=$(printf '%s\n' "${MENU_ENTRIES[@]}" | hypr_rofi_dmenu "Menu" 15 400px)

case "$CHOICE" in
  *"Lock Screen"*)    hypr-lock ;;
  *"Power Menu"*)     hypr-power-menu ;;
  *"Wifi"*)           hypr-wifi-menu ;;
  *"Bluetooth"*)      hypr-bluetooth-menu ;;
  *"Audio Devices"*)  hypr-audio-device-menu ;;
  *"Keyboard"*)       hypr-keyboard-menu ;;
  *"USB"*)            hypr-usb-menu ;;
  *"Performance"*)    hypr-performance-menu ;;
  *"Kill Window"*)    hypr-kill-windows ;;
  *"Clipboard"*)      hypr-rofi-clipboard ;;
  *"SSH"*)            hypr-rofi-ssh-host ;;
  *"Open File"*)      hypr-rofi-open-file ;;
  *"Calc"*)           hypr-rofi-calc ;;
  *"Obsidian"*)       hypr-obsidian-open-or-focus ;;
  *"Webapp"*)         hypr-webapp-maker ;;
esac
