#!/bin/sh
set -eu

MIN_RSS_KB="${MIN_RSS_KB:-10240}"
PROMPT="${PROMPT:-Kill process> }"
CURRENT_UID="$(id -u)"
CURRENT_USER="$(id -un)"
SELF_PID="$$"

notice() {
  message="$1"
  if command -v notify-send >/dev/null 2>&1; then
    notify-send "Kill windows" "$message" 2>/dev/null || true
  fi
  printf '%s\n' "$message" >&2
}

need() {
  if ! command -v "$1" >/dev/null 2>&1; then
    notice "Missing command: $1"
    exit 1
  fi
}

rss_kb() {
  pid="$1"
  [ -r "/proc/$pid/status" ] || { printf '0\n'; return; }
  awk -v uid="$CURRENT_UID" '
    /^Uid:/ { owned = ($2 == uid) }
    /^VmRSS:/ { rss = $2 }
    END { if (owned && rss != "") print rss + 0; else print 0 }
  ' "/proc/$pid/status" 2>/dev/null || printf '0\n'
}

skip_process() {
  comm="$1"
  case "$comm" in
    labwc|waybar|swaync|dunst|wl-paste|cliphist|pipewire*|wireplumber|dbus-daemon|systemd|ssh-agent|gpg-agent|gnome-keyring*|nm-applet|blueman-applet|polkit-*|xdg-desktop-portal*|fuzzel|sh|bash|fish|zsh|ps|awk|sort|sed|cut|grep|labwc-kill-windows)
      return 0
      ;;
  esac
  return 1
}

safe_text() {
  printf '%s' "$1" | tr '\t\r\n' '   '
}

need fuzzel
need ps

tmp="$(mktemp)"
labels="$(mktemp)"
trap 'rm -f "$tmp" "$labels"' EXIT

ps -u "$CURRENT_USER" -o rss=,pid=,comm=,args= \
  | while read -r rss pid comm args; do
      case "$pid" in ''|*[!0-9]*) continue ;; esac
      [ "$pid" -ne "$SELF_PID" ] || continue
      case "$rss" in ''|*[!0-9]*) continue ;; esac
      [ "$rss" -gt "$MIN_RSS_KB" ] || continue
      if skip_process "${comm:-}"; then
        continue
      fi

      verified_rss="$(rss_kb "$pid")"
      [ "$verified_rss" -gt "$MIN_RSS_KB" ] || continue

      comm="$(safe_text "${comm:-unknown}")"
      args="$(safe_text "${args:-}")"
      mb="$(awk -v rss="$verified_rss" 'BEGIN { printf "%.1f", rss / 1024 }')"
      label="$(printf '%7s MB  PID %-7s  %s — %s' "$mb" "$pid" "$comm" "$args")"
      printf '%010d\t%s\t%s\n' "$verified_rss" "$pid" "$label" >> "$tmp"
    done

if [ ! -s "$tmp" ]; then
  notice "No user application process over 10 MB."
  exit 0
fi

sort -rn -k1,1 "$tmp" | cut -f3- > "$labels"
selection="$(fuzzel --dmenu --prompt "$PROMPT" --width 100 --lines 14 < "$labels" || true)"
[ -n "$selection" ] || exit 0

pid="$(awk -F '\t' -v label="$selection" '$3 == label { print $2; exit }' "$tmp")"
case "$pid" in ''|*[!0-9]*) exit 1 ;; esac

rss="$(rss_kb "$pid")"
[ "$rss" -gt "$MIN_RSS_KB" ] || { notice "Process $pid is no longer an eligible user application."; exit 0; }

kill -TERM -- "$pid" 2>/dev/null || notice "Could not terminate PID $pid."
