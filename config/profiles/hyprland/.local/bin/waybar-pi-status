#!/usr/bin/env bash
set -euo pipefail

cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}"
cache_file="$cache_dir/waybar-pi-status.json"
ttl="${WAYBAR_PI_STATUS_TTL:-21600}"
pi_npm_package="${WAYBAR_PI_NPM_PACKAGE:-@earendil-works/pi-coding-agent}"
pi_extensions_prefix="${WAYBAR_PI_EXTENSIONS_PREFIX:-$HOME/.pi/agent/npm}"
pi_git_root="${WAYBAR_PI_GIT_ROOT:-$HOME/.pi/agent/git}"
pi_distrobox="${WAYBAR_PI_STATUS_DISTROBOX:-arch}"

if [ "${WAYBAR_PI_STATUS_IN_CONTAINER:-0}" != "1" ] && ! command -v pi >/dev/null 2>&1 && command -v distrobox-enter >/dev/null 2>&1; then
  exec distrobox-enter "$pi_distrobox" -- env \
    WAYBAR_PI_STATUS_IN_CONTAINER=1 \
    WAYBAR_PI_STATUS_TTL="$ttl" \
    WAYBAR_PI_NPM_PACKAGE="$pi_npm_package" \
    WAYBAR_PI_EXTENSIONS_PREFIX="$pi_extensions_prefix" \
    WAYBAR_PI_GIT_ROOT="$pi_git_root" \
    bash "$0" "$@"
fi

json_escape() {
  python3 -c 'import json,sys; print(json.dumps(sys.stdin.read())[1:-1])'
}

emit_json() {
  class="$1"
  tooltip="$2"
  tooltip_json="$(printf '%s' "$tooltip" | json_escape)"
  printf '{"text":"Pi","tooltip":"%s","class":"%s"}\n' "$tooltip_json" "$class"
}

cache_is_fresh() {
  [ -r "$cache_file" ] || return 1
  now="$(date +%s)"
  mtime="$(stat -c %Y "$cache_file" 2>/dev/null || echo 0)"
  [ $((now - mtime)) -lt "$ttl" ]
}

pi_current_version() {
  pkg_json="$(npm root -g 2>/dev/null)/$pi_npm_package/package.json"
  if [ -r "$pkg_json" ] && command -v node >/dev/null 2>&1; then
    node -e 'console.log(require(process.argv[1]).version)' "$pkg_json" 2>/dev/null && return 0
  fi
  pi --version 2>/dev/null || true
}

append_line() {
  var_name="$1"
  line="$2"
  current="${!var_name:-}"
  if [ -n "$current" ]; then
    printf -v "$var_name" '%s\n%s' "$current" "$line"
  else
    printf -v "$var_name" '%s' "$line"
  fi
}

check_pi_self() {
  current="$(pi_current_version | head -n 1)"
  latest="$(npm view "$pi_npm_package" version --silent 2>/dev/null || true)"

  if [ -z "$current" ]; then
    append_line notes "Pi: no se pudo leer versión local"
    return
  fi
  if [ -z "$latest" ]; then
    append_line notes "Pi: sin datos remotos (local $current)"
    return
  fi

  if [ "$current" != "$latest" ]; then
    outdated=1
    append_line problems "Pi $current → $latest"
  else
    append_line notes "Pi listo ($current)"
  fi
}

check_npm_extensions() {
  [ -d "$pi_extensions_prefix" ] || return 0
  out="$(npm outdated --prefix "$pi_extensions_prefix" --json 2>/dev/null || true)"
  if [ -z "$out" ] || [ "$out" = "{}" ]; then
    append_line notes "Extensiones npm listas"
    return
  fi

  parsed="$(printf '%s' "$out" | node -e '
let input=""; process.stdin.on("data", d => input += d); process.stdin.on("end", () => {
  try {
    const data = JSON.parse(input || "{}");
    for (const [name, info] of Object.entries(data)) {
      console.log(`${name} ${info.current || "?"} → ${info.latest || info.wanted || "?"}`);
    }
  } catch {}
});
' 2>/dev/null || true)"

  if [ -n "$parsed" ]; then
    outdated=1
    while IFS= read -r line; do
      append_line problems "npm:$line"
    done <<EOF
$parsed
EOF
  else
    append_line notes "Extensiones npm: salida no interpretable"
  fi
}

check_git_extensions() {
  [ -d "$pi_git_root" ] || return 0
  found=0
  while IFS= read -r git_dir; do
    repo="${git_dir%/.git}"
    found=1
    name="${repo#$pi_git_root/}"
    branch="$(git -C "$repo" rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
    local_rev="$(git -C "$repo" rev-parse HEAD 2>/dev/null || true)"
    [ -n "$branch" ] && [ "$branch" != "HEAD" ] || branch="main"
    remote_rev="$(git -C "$repo" ls-remote origin "refs/heads/$branch" 2>/dev/null | awk '{print $1; exit}')"

    if [ -z "$local_rev" ]; then
      append_line notes "$name: no se pudo leer rev local"
      continue
    fi
    if [ -z "$remote_rev" ]; then
      append_line notes "$name: sin datos remotos"
      continue
    fi
    if [ "$local_rev" != "$remote_rev" ]; then
      outdated=1
      append_line problems "git:$name ($branch)"
    fi
  done < <(find "$pi_git_root" -type d -name .git 2>/dev/null | sort)

  if [ "$found" -eq 1 ]; then
    append_line notes "Extensiones git revisadas"
  fi
}

status_json() {
  outdated=0
  problems=""
  notes=""

  check_pi_self
  check_npm_extensions
  check_git_extensions

  if [ "$outdated" -eq 1 ]; then
    tooltip="$(printf 'Pi desactualizado\n%s\n\nClick: pi update' "$problems")"
    emit_json outdated "$tooltip"
  else
    tooltip="$(printf 'Pi listo\n%s\n\nClick: pi update' "$notes")"
    emit_json ready "$tooltip"
  fi
}

run_self_test() {
  tmp="$(mktemp -d)"
  trap 'rm -rf "$tmp"' EXIT INT TERM
  WAYBAR_PI_STATUS_TTL=999999 XDG_CACHE_HOME="$tmp" "$0" --from-cache >/dev/null 2>&1 && {
    echo "self-test failed: unexpected cache" >&2
    exit 1
  }
  output="$(WAYBAR_PI_STATUS_TTL=0 XDG_CACHE_HOME="$tmp" WAYBAR_PI_GIT_ROOT="$tmp/git" WAYBAR_PI_EXTENSIONS_PREFIX="$tmp/npm" "$0")"
  printf '%s\n' "$output" | grep -Eq '"text":"Pi"'
  printf '%s\n' "$output" | grep -Eq '"class":"(ready|outdated)"'
  echo "self-test ok"
}

case "${1:-status}" in
  status)
    if cache_is_fresh; then
      cat "$cache_file"
      exit 0
    fi
    mkdir -p "$cache_dir"
    tmp="$(mktemp "$cache_dir/waybar-pi-status.XXXXXX")"
    status_json > "$tmp"
    mv "$tmp" "$cache_file"
    cat "$cache_file"
    ;;
  --refresh|refresh)
    rm -f "$cache_file"
    "$0" status
    ;;
  --from-cache)
    cache_is_fresh && cat "$cache_file"
    ;;
  --self-test)
    run_self_test
    ;;
  *)
    echo "usage: waybar-pi-status [status|refresh|--self-test]" >&2
    exit 2
    ;;
esac
