#!/usr/bin/env bash
set -euo pipefail

theme="${HYPR_ROFI_THEME:-$HOME/.config/rofi/hypr-menu.rasi}"
apps_dir="${XDG_DATA_HOME:-$HOME/.local/share}/applications"
icons_dir="${XDG_DATA_HOME:-$HOME/.local/share}/icons"
state_dir="${XDG_DATA_HOME:-$HOME/.local/share}/hypr/webapps"
bin_dir="$state_dir/bin"
profile_dir="$state_dir/profiles"

ask() { local prompt="$1" initial="${2:-}"; printf '%s' "$initial" | rofi -dmenu -i -p "$prompt" -theme "$theme"; }
choose() { local prompt="$1"; shift; printf '%s\n' "$@" | rofi -dmenu -i -p "$prompt" -theme "$theme"; }
notify() { notify-send "Hypr Web App Maker" "$1" 2>/dev/null || true; }
slugify() { printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//; s/-+/-/g'; }
desktop_escape() { printf '%s' "$1" | tr '\n\r' '  ' | sed 's/\\/\\\\/g; s/;/\\;/g'; }
single_line() { printf '%s' "$1" | tr '\n\r' '  '; }
url_origin() { printf '%s' "$1" | sed -E 's#^(https?://[^/]+).*#\1#'; }
domain_of() { printf '%s' "$1" | sed -E 's#^https?://([^/]+).*#\1#'; }

browser_candidates() {
  command -v chromium >/dev/null 2>&1 && echo chromium
  command -v brave >/dev/null 2>&1 && echo brave
  command -v brave-browser >/dev/null 2>&1 && echo brave-browser
  if command -v flatpak >/dev/null 2>&1 && flatpak info com.brave.Browser >/dev/null 2>&1; then echo "flatpak:com.brave.Browser"; fi
}

download_icon() {
  local url="$1" icon_path="$2" origin domain tmp
  origin="$(url_origin "$url")"
  domain="$(domain_of "$url")"
  tmp="$(mktemp)"
  trap 'rm -f "$tmp"' RETURN

  if command -v wget >/dev/null 2>&1; then
    wget -qO "$tmp" "$origin/favicon.ico" || true
    if [ -s "$tmp" ]; then mv "$tmp" "$icon_path"; return 0; fi
    wget -qO "$tmp" "https://www.google.com/s2/favicons?domain_url=$domain&sz=256" || true
    if [ -s "$tmp" ]; then mv "$tmp" "$icon_path"; return 0; fi
  fi
  return 1
}

set_icon_from_user_input() {
  local input="$1" icon_path="$2"
  [ -n "$input" ] || return 1
  case "$input" in
    http://*|https://*)
      command -v wget >/dev/null 2>&1 || return 1
      wget -qO "$icon_path" "$input"
      ;;
    /*|~/*)
      input="${input/#\~/$HOME}"
      [ -f "$input" ] || return 1
      cp "$input" "$icon_path"
      ;;
    *) return 1 ;;
  esac
}

name="$(ask 'App name' || true)"; name="$(single_line "$name" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"; [ -n "$name" ] || exit 0
url="$(ask 'URL' 'https://' || true)"; url="$(single_line "$url" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"; [ -n "$url" ] || exit 0
case "$url" in http://*|https://*) ;; *) url="https://$url" ;; esac

slug="$(slugify "$name")"; [ -n "$slug" ] || slug="hypr-webapp"
app_id="hypr-webapp-$slug"
launcher="$bin_dir/$app_id"
desktop_file="$apps_dir/$slug.desktop"
app_profile="$profile_dir/$slug"
class="chrome-$(domain_of "$url" | sed -E 's/[^A-Za-z0-9]/-/g')__-Default"
icon_path="$icons_dir/$slug.png"

if [ -e "$desktop_file" ]; then
  overwrite="$(choose "Overwrite $name?" 'Yes, overwrite' 'No, cancel' || true)"
  case "$overwrite" in
    Yes*) ;;
    *) notify 'Cancelled. Existing app preserved.'; exit 0 ;;
  esac
fi

browser_list="$(browser_candidates | awk 'NF')"
if [ -z "$browser_list" ]; then notify 'No Chromium-compatible browser found.'; exit 1; fi
browser="$(printf '%s\n' "$browser_list" | rofi -dmenu -i -p 'Browser' -theme "$theme" || true)"; [ -n "$browser" ] || exit 0

mkdir -p "$apps_dir" "$icons_dir" "$bin_dir" "$profile_dir"
if ! download_icon "$url" "$icon_path"; then
  logo_input="$(ask 'Logo URL/path' "$url" || true)"
  logo_input="$(single_line "$logo_input" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
  set_icon_from_user_input "$logo_input" "$icon_path" || icon_path="chromium"
fi

q_url="$(printf '%q' "$url")"; q_profile="$(printf '%q' "$app_profile")"; q_class="$(printf '%q' "$class")"; q_browser="$(printf '%q' "$browser")"
cat > "$launcher" <<EOF_LAUNCHER
#!/usr/bin/env bash
set -euo pipefail
url=$q_url
profile=$q_profile
class=$q_class
browser=$q_browser
mkdir -p "\$profile"
case "\$browser" in
  chromium|brave|brave-browser)
    exec "\$browser" --app="\$url" --new-window --class="\$class" --user-data-dir="\$profile"
    ;;
  flatpak:com.brave.Browser)
    exec flatpak run com.brave.Browser --app="\$url" --new-window --class="\$class" --user-data-dir="\$profile"
    ;;
  *) exec "\$browser" "\$url" ;;
esac
EOF_LAUNCHER
chmod +x "$launcher"
cat > "$desktop_file" <<EOF_DESKTOP
[Desktop Entry]
Type=Application
Name=$(desktop_escape "$name")
Comment=$(desktop_escape "$name") Web Application
Exec=$launcher
Icon=$(desktop_escape "$icon_path")
Terminal=false
Categories=Network;WebBrowser;
StartupNotify=true
StartupWMClass=$class
X-Hypr-WebApp=true
X-Hypr-WebApp-URL=$(desktop_escape "$url")
X-Hypr-WebApp-Browser=$(desktop_escape "$browser")
EOF_DESKTOP
update-desktop-database "$apps_dir" >/dev/null 2>&1 || true
notify "Created $name"
