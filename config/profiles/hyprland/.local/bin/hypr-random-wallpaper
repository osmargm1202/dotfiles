#!/usr/bin/env bash
set -euo pipefail

interval="${SWAY_WALLPAPER_INTERVAL:-1800}"
current_file="${XDG_STATE_HOME:-$HOME/.local/state}/hypr-random-wallpaper.current"
daemon_pid_file="${XDG_RUNTIME_DIR:-/tmp}/hypr-random-wallpaper.daemon.pid"
wallpaper_dir="${WALLPAPER_DIR:-$HOME/Pictures/Wallpapers}"

pick_wallpaper() {
  [ -d "$wallpaper_dir" ] || return 1

  find "$wallpaper_dir" -type f \( \
    -iname '*.jpg' -o \
    -iname '*.jpeg' -o \
    -iname '*.png' -o \
    -iname '*.webp' \
  \) | shuf -n 1
}

set_wallpaper() {
  local wallpaper="$1"

  mkdir -p "$(dirname "$current_file")"
  printf '%s\n' "$wallpaper" >"$current_file"

  if command -v hyprctl >/dev/null 2>&1; then
    hyprctl hyprpaper preload "$wallpaper" >/dev/null 2>&1 || true
    hyprctl hyprpaper wallpaper ",$wallpaper" >/dev/null 2>&1 || \
      hyprctl dispatch exec "hyprctl hyprpaper wallpaper ,$wallpaper" >/dev/null 2>&1 || \
      hyprctl keyword misc:background_color "rgba(000000ff)" >/dev/null 2>&1 || true
  fi
}

next_wallpaper() {
  local wallpaper
  wallpaper="$(pick_wallpaper)" || {
    echo "hypr-random-wallpaper: no wallpapers found in $wallpaper_dir" >&2
    return 1
  }

  set_wallpaper "$wallpaper"
}

is_own_daemon_pid() {
  local pid="$1"
  local args

  case "$pid" in
    ''|*[!0-9]*) return 1 ;;
  esac

  kill -0 "$pid" 2>/dev/null || return 1
  args="$(ps -p "$pid" -o args= 2>/dev/null)" || return 1

  case "$args" in
    *hypr-random-wallpaper*|*"$0"*) return 0 ;;
    *) return 1 ;;
  esac
}

run_daemon() {
  mkdir -p "$(dirname "$daemon_pid_file")"
  if [ -f "$daemon_pid_file" ]; then
    local old_pid
    old_pid="$(cat "$daemon_pid_file")"
    if [ "$old_pid" != "$$" ] && is_own_daemon_pid "$old_pid"; then
      kill "$old_pid" 2>/dev/null || true
    fi
    rm -f "$daemon_pid_file"
  fi
  printf '%s\n' "$$" >"$daemon_pid_file"
  trap 'rm -f "$daemon_pid_file"' EXIT INT TERM

  while :; do
    next_wallpaper || true
    sleep "$interval"
  done
}

stop_daemon() {
  [ -f "$daemon_pid_file" ] || return 0
  local pid
  pid="$(cat "$daemon_pid_file")"
  if is_own_daemon_pid "$pid"; then
    kill "$pid" 2>/dev/null || true
  fi
  rm -f "$daemon_pid_file"
}

case "${1:-daemon}" in
  next)
    next_wallpaper
    ;;
  daemon)
    run_daemon
    ;;
  stop)
    stop_daemon
    ;;
  *)
    echo "Usage: ${0##*/} [next|daemon|stop]" >&2
    exit 2
    ;;
esac
