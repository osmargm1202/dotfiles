#!/usr/bin/env bash
set -euo pipefail

notify() {
  notify-send "USB headset" "$1" 2>/dev/null || true
}

cmd="${HYPR_HEADSET_RECONNECT_CMD:-hypr-usb-menu reconnect-headset}"

if command -v kitty >/dev/null 2>&1; then
  kitty --title "USB headset reconnect" -e fish -lc "$cmd" &
  exit 0
fi

if command -v fish >/dev/null 2>&1; then
  fish -lc "$cmd"
  exit 0
fi

notify "fish no está instalado; no puedo reconectar el headset USB."
exit 1
