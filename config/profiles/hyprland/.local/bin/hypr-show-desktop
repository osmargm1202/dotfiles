#!/usr/bin/env bash
# Toggle workspace 11 (empty desktop view) and back.
# Pressing once: save current workspace, go to 11.
# Pressing again: return to saved workspace.
set -euo pipefail

STATE_FILE="/tmp/hypr-show-desktop-prev-ws"
CURRENT_WS=$(hyprctl activeworkspace -j | jq -r '.id')

if [ "$CURRENT_WS" = "11" ]; then
    if [ -f "$STATE_FILE" ]; then
        PREV_WS=$(cat "$STATE_FILE")
        rm -f "$STATE_FILE"
        hyprctl dispatch workspace "$PREV_WS"
    else
        hyprctl dispatch workspace 1
    fi
else
    echo "$CURRENT_WS" > "$STATE_FILE"
    hyprctl dispatch workspace 11
fi
