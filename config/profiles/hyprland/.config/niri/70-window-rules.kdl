window-rule {
    geometry-corner-radius 8
    clip-to-geometry true
    opacity 0.97
}

window-rule {
    match app-id="org.pulseaudio.pavucontrol"
    match app-id="org.gnome.Calculator"

    default-column-width { proportion 0.3; }
    default-window-height { proportion 0.4; }
    open-floating true
}

window-rule {
    match app-id="orgmai-chat"
    default-column-width { proportion 0.4; }
    default-window-height { proportion 0.5; }
    open-floating true
}

window-rule {
    match app-id="windows-rdp"
    open-focused false
    open-maximized true
    open-floating false
    tiled-state false
    opacity 1.0
}

window-rule {
    match app-id="steam" title=r#"^notificationtoasts_\d+_desktop$"#
    default-floating-position x=10 y=10 relative-to="bottom-right"
}

window-rule {
    match app-id="Kitty$"
    opacity 0.95
}

window-rule {
    match app-id="pi$"
    match app-id="Chromium$"
    match app-id="Claude$"
    match app-id="org.chromium.Chromium"        // Chromium Flatpak
    match app-id="Chromium"                     // Chromium - mayúscula
    open-maximized true
    opacity 0.97
}

window-rule {
    match app-id=r#"^chrome.*"#  // Coincide cualquier ventana cuyo app-id empiece con "chrome"
    match app-id=r#"^Chrome.*"#  // Coincide cualquier ventana cuyo app-id empiece con "chrome"
    match app-id=r#"^org.chromium.Chromium.*"#  // Coincide cualquier ventana cuyo app-id empiece con "chrome"
    default-column-width { proportion 0.5; }
    default-window-height { proportion 1.0; }
    default-floating-position x=0 y=0 relative-to="left"
}

window-rule {
    match app-id="rofi"
    open-floating true
    opacity 0.80
}
