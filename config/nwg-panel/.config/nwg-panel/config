[
  {
    "name": "labwc-top",
    "output": "",
    "layer": "top",
    "position": "top",
    "controls": "right",
    "width": "auto",
    "height": 34,
    "homogeneous": true,
    "margin-top": 0,
    "margin-bottom": 0,
    "padding-horizontal": 6,
    "padding-vertical": 0,
    "spacing": 6,
    "items-padding": 2,
    "icons": "light",
    "css-name": "panel-top",
    "modules-left": ["launcher"],
    "modules-center": ["clock"],
    "modules-right": ["tray"],
    "launcher": {
      "command": "fuzzel",
      "icon": "view-grid-symbolic",
      "label": "",
      "label-position": "right",
      "css-name": "launcher",
      "icon-size": 18
    },
    "controls-settings": {
      "components": ["brightness", "volume", "battery"],
      "commands": {
        "battery": ""
      },
      "show-values": false,
      "interval": 1,
      "icon-size": 16,
      "hover-opens": false,
      "leave-closes": true,
      "click-closes": false,
      "css-name": "controls-window",
      "custom-items": [
        {
          "name": "Panel settings",
          "icon": "nwg-panel",
          "cmd": "nwg-panel-config"
        }
      ],
      "menu": {
        "name": "Power",
        "icon": "system-shutdown-symbolic",
        "items": [
          {
            "name": "Lock",
            "cmd": "swaylock -f -c 000000"
          },
          {
            "name": "Logout",
            "cmd": "loginctl terminate-user $USER"
          },
          {
            "name": "Reboot",
            "cmd": "systemctl reboot"
          },
          {
            "name": "Shutdown",
            "cmd": "systemctl poweroff"
          }
        ]
      }
    },
    "tray": {
      "root-css-name": "tray",
      "inner-css-name": "inner-tray"
    },
    "clock": {
      "format": "%H:%M",
      "tooltip-text": "%A %d %B %Y",
      "on-left-click": "",
      "on-middle-click": "",
      "on-right-click": "",
      "on-scroll-up": "",
      "on-scroll-down": "",
      "css-name": "clock",
      "interval": 1
    },
    "menu-start": "off",
    "exclusive-zone": true,
    "sigrt": 64,
    "use-sigrt": false,
    "scratchpad": {},
    "sway-mode": {},
    "sway-taskbar": {},
    "sway-workspaces": {},
    "openweather": {},
    "brightness-slider": {},
    "playerctl": {},
    "dwl-tags": {},
    "hyprland-taskbar": {},
    "hyprland-workspaces": {}
  }
]
